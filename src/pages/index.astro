---
import BaseLayout from '@/layouts/BaseLayout.astro';
import StatsBar from '@/components/StatsBar.astro';
import HubCard from '@/components/HubCard.astro';
import ProcessSteps from '@/components/ProcessSteps.astro';
import CTABanner from '@/components/CTABanner.astro';
import TestimonialCard from '@/components/TestimonialCard.astro';
import { buildWebSiteSchema, buildOrganizationSchema } from '@/lib/schema';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What does an AI consultant do?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'An AI consultant helps businesses identify where artificial intelligence can add value, designs a strategy to implement it, and either builds the solution or oversees its development. At Agentic AI Associates, we cover the full lifecycle: from initial AI readiness audit through to deployment, team training, and ongoing optimisation.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much does AI consultancy cost in the UK?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'AI consultancy in the UK typically ranges from £5,000 for a focused strategy engagement to £50,000+ for full implementation projects. Costs depend on scope, complexity, and the number of systems involved. We offer a free initial consultation to scope your project and provide a clear, fixed-price proposal.',
      },
    },
    {
      '@type': 'Question',
      name: 'How long does an AI project take?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A focused AI strategy engagement takes 2-4 weeks. Implementation projects typically deliver first results within 6-8 weeks, with full deployment in 3-6 months. Agentic AI systems with complex workflow automation can take longer depending on integration requirements.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do I need technical expertise to work with you?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. We work with business owners, operations directors, and leadership teams who understand their business challenges but not necessarily AI technology. We handle the technical complexity and communicate in plain language throughout.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is agentic AI?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Agentic AI refers to AI systems that can take sequences of actions autonomously to complete complex, multi-step tasks — rather than simply responding to single prompts. These systems use tools, browse data sources, make decisions, and loop back to check their work, enabling automation of workflows that previously required human judgment.',
      },
    },
  ],
};

const schemas = [buildWebSiteSchema(), buildOrganizationSchema(), faqSchema];

const services = [
  { title: 'AI Strategy & Roadmaps', description: 'Clear, actionable plans for AI adoption. We audit your readiness, identify opportunities, and build a roadmap with measurable ROI.', href: '/services/ai-strategy/', icon: 'strategy' },
  { title: 'AI Implementation', description: 'We build and deploy AI systems that work. From chatbots to data pipelines, integrated with your existing tech stack.', href: '/services/ai-implementation/', icon: 'implementation' },
  { title: 'Agentic AI', description: 'Autonomous AI agents that handle complex workflows. We design, build, and deploy agentic systems tailored to your business.', href: '/services/agentic-ai/', icon: 'agentic' },
  { title: 'Generative AI', description: 'LLMs, RAG systems, and AI-powered content generation. We help you harness generative AI safely and effectively.', href: '/services/generative-ai/', icon: 'sparkles' },
  { title: 'Data & AI', description: 'Turn your data into a competitive advantage. We build data pipelines, analytics, and AI models that deliver insight.', href: '/services/data-and-ai/', icon: 'data' },
  { title: 'AI Training & Workshops', description: 'Upskill your team on AI tools, prompt engineering, and responsible AI adoption. Hands-on, practical sessions.', href: '/services/ai-training/', icon: 'training' },
];

const industries = [
  { title: 'Healthcare', description: 'Clinical AI, patient data, compliance automation.', href: '/industries/healthcare/', icon: 'healthcare' },
  { title: 'Legal', description: 'Contract analysis, case research, compliance monitoring.', href: '/industries/legal/', icon: 'legal' },
  { title: 'Finance', description: 'Fraud detection, risk assessment, automated reporting.', href: '/industries/finance/', icon: 'finance' },
  { title: 'Retail', description: 'Demand forecasting, personalisation, inventory optimisation.', href: '/industries/retail/', icon: 'retail' },
  { title: 'Manufacturing', description: 'Predictive maintenance, quality control, supply chain AI.', href: '/industries/manufacturing/', icon: 'manufacturing' },
  { title: 'Education', description: 'Adaptive learning, admin automation, student analytics.', href: '/industries/education/', icon: 'education' },
];

const testimonials = [
  { quote: "Agentic AI Associates took our vague ideas about automation and turned them into a concrete roadmap with clear ROI projections. Six months in, we've already hit the targets they promised.", name: "Sarah Mitchell", role: "Operations Director", company: "Precision Parts UK" },
  { quote: "The team understood our regulatory constraints immediately and never once suggested something that would have created compliance headaches. That domain knowledge is rare.", name: "James Okafor", role: "Head of Technology", company: "Meridian Legal Group" },
  { quote: "We'd been burned by a previous AI project that delivered a demo and nothing else. This time we got a working system, trained staff, and measurable results within eight weeks.", name: "Rachel Thornton", role: "CEO", company: "Brightfield Retail" },
];

const techPartners = [
  { name: 'Microsoft Azure' },
  { name: 'Google Cloud' },
  { name: 'Amazon Web Services' },
  { name: 'OpenAI' },
  { name: 'Anthropic' },
  { name: 'HuggingFace' },
];
---

<BaseLayout
  title="AI Consultancy UK — Agentic AI Associates | Strategy, Implementation & Training"
  description="UK AI consultancy specialising in agentic AI, generative AI, and data-driven solutions. We help businesses implement AI strategy, automation, and intelligent systems that deliver measurable results."
  schema={schemas}
>
  <!-- HERO -->
  <section class="relative overflow-hidden noise-overlay" style="background: #080f1e;">
    <!-- Aurora blobs -->
    <div class="aurora-blob w-[600px] h-[600px] top-[-100px] left-[-100px]" style="background: #1e3a5f;"></div>
    <div class="aurora-blob w-[500px] h-[500px] bottom-[-80px] right-[-80px]" style="background: #0d9488;"></div>
    <!-- Dot grid overlay -->
    <div class="absolute inset-0 dot-grid opacity-[0.06]"></div>

    <div class="container relative section" style="padding-top: 7rem; padding-bottom: 7rem;">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-teal-500/30 bg-teal-500/10 text-teal-300 text-xs font-semibold tracking-wide mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-teal-400 animate-pulse"></span>
        UK-Based AI Consultancy
      </div>

      <h1 class="text-white max-w-4xl leading-[1.05] text-5xl md:text-6xl lg:text-7xl font-[family-name:var(--font-display)] font-extrabold tracking-tight">
        AI that actually<br>
        <span style="background: linear-gradient(135deg, #38bdf8, #0d9488); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">delivers results</span>
      </h1>

      <p class="text-xl text-slate-300 mt-6 max-w-2xl leading-relaxed">
        Strategy, implementation, and training from consultants who've built real systems for real businesses. No demos that don't ship. No strategies that gather dust.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mt-10">
        <a href="/contact/" class="btn-glow text-base">
          Book a Free Consultation
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="/services/" class="btn" style="background: rgba(255,255,255,0.08); color: #e2e8f0; border: 1px solid rgba(255,255,255,0.15);">
          Explore Services
        </a>
      </div>

      <!-- Trust line -->
      <p class="mt-10 text-xs text-slate-500 uppercase tracking-widest font-medium">Trusted by teams at</p>
      <div class="flex flex-wrap items-center gap-8 mt-4">
        {techPartners.map(p => (
          <span class="text-slate-400 text-sm font-semibold tracking-wide opacity-60 hover:opacity-100 transition-opacity">{p.name}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS STRIP -->
  <section class="border-b border-slate-100">
    <div class="container">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-slate-100">
        {[
          { value: '50+', label: 'AI projects delivered' },
          { value: '12', label: 'Industries served' },
          { value: '98%', label: 'Client satisfaction' },
          { value: '< 8wk', label: 'Avg. time to first result' },
        ].map(stat => (
          <div class="py-12 px-8 text-center">
            <div class="text-3xl md:text-4xl font-extrabold font-[family-name:var(--font-display)]" style="background: linear-gradient(135deg, #2563eb, #0d9488); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">{stat.value}</div>
            <div class="text-sm text-slate-500 mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-14">
        <p class="text-xs font-bold text-teal-600 mb-3 uppercase tracking-[0.2em]">What We Do</p>
        <h2 class="text-4xl font-extrabold">AI Consultancy Services</h2>
        <p class="text-slate-500 mt-4 max-w-xl mx-auto text-lg">From strategy to deployment — we cover the full AI lifecycle so you get real results, not just a report.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((svc) => (
          <HubCard title={svc.title} description={svc.description} href={svc.href} icon={svc.icon} />
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/services/" class="btn btn-outline">View All Services</a>
      </div>
    </div>
  </section>

  <!-- WHY US — 3-column feature row -->
  <section class="section" style="background: #f8fafc;">
    <div class="container">
      <div class="text-center mb-14">
        <p class="text-xs font-bold text-teal-600 mb-3 uppercase tracking-[0.2em]">Why Agentic AI Associates</p>
        <h2 class="text-4xl font-extrabold">The consulting firm that actually builds</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', title: 'No demo theatre', body: "We don't build impressive demos that fall apart in production. Every project ends with a working system your team can operate and maintain." },
          { icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', title: 'ROI-first approach', body: 'Every recommendation starts with a business case. We tell you the expected return, the timeline to see it, and what it will take to get there.' },
          { icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z', title: 'UK-based expertise', body: 'You work directly with senior consultants, not junior contractors. We understand UK regulation, data sovereignty, and the business landscape you operate in.' },
        ].map(f => (
          <div class="card-animated-border p-8">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background: rgba(13,148,136,0.1);">
              <svg class="w-6 h-6" style="color: #0d9488;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={f.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">{f.title}</h3>
            <p class="text-slate-500 leading-relaxed">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INDUSTRIES -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-14">
        <p class="text-xs font-bold text-teal-600 mb-3 uppercase tracking-[0.2em]">Industries</p>
        <h2 class="text-4xl font-extrabold">AI solutions for your sector</h2>
        <p class="text-slate-500 mt-4 max-w-xl mx-auto text-lg">Every industry has unique challenges. We bring deep domain knowledge and sector-specific experience to every project.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {industries.map((ind) => (
          <HubCard title={ind.title} description={ind.description} href={ind.href} icon={ind.icon} />
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/industries/" class="btn btn-outline">View All Industries</a>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section" style="background: #f8fafc;">
    <div class="container">
      <ProcessSteps />
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-14">
        <p class="text-xs font-bold text-teal-600 mb-3 uppercase tracking-[0.2em]">Client Results</p>
        <h2 class="text-4xl font-extrabold">What our clients say</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonials.map(t => (
          <TestimonialCard quote={t.quote} name={t.name} role={t.role} company={t.company} />
        ))}
      </div>
    </div>
  </section>

  <!-- FOR YOUR BUSINESS SIZE -->
  <section class="section" style="background: #080f1e; position: relative; overflow: hidden;">
    <div class="aurora-blob w-[400px] h-[400px] top-0 right-0" style="background: #0d9488;"></div>
    <div class="dot-grid absolute inset-0 opacity-[0.05]"></div>
    <div class="container relative">
      <div class="text-center mb-14">
        <p class="text-xs font-bold mb-3 uppercase tracking-[0.2em]" style="color: #5eead4;">For Every Business</p>
        <h2 class="text-4xl font-extrabold text-white">AI consultancy scaled to you</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { title: 'Small Business', body: 'Affordable AI that punches above its weight. Start small, scale fast.', href: '/for/small-business/' },
          { title: 'Startups', body: 'Move fast with AI baked in from day one. Lean, focused, no bloat.', href: '/for/startups/' },
          { title: 'SMEs', body: 'Bridge the gap between ambition and capability. AI that fits your budget.', href: '/for/smes/' },
          { title: 'Enterprise', body: "Complex systems, multiple stakeholders, high stakes. We've been there.", href: '/for/enterprise/' },
        ].map(b => (
          <a href={b.href} class="glass-card p-6 group hover:border-teal-500/30 transition-all" style="text-decoration: none;">
            <h3 class="text-lg font-bold text-white mb-2 group-hover:text-teal-300 transition-colors">{b.title}</h3>
            <p class="text-sm text-slate-400 leading-relaxed">{b.body}</p>
            <span class="mt-4 text-xs font-semibold text-teal-400 flex items-center gap-1 group-hover:gap-2 transition-all">
              Learn more
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TECH PARTNERS -->
  <section class="py-20 border-y border-slate-100">
    <div class="container">
      <p class="text-center text-xs font-semibold text-slate-400 uppercase tracking-widest mb-10">Technology Partners &amp; Platforms</p>
      <div class="flex flex-wrap justify-center items-center gap-10">
        {[
          'Microsoft Azure', 'Google Cloud', 'Amazon Web Services', 'OpenAI', 'Anthropic', 'HuggingFace', 'Snowflake', 'Databricks'
        ].map(name => (
          <span class="text-sm font-bold text-slate-400 tracking-wide trust-bar-logo">{name}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ for AI Search -->
  <section class="section bg-[var(--color-surface)]">
    <div class="container max-w-3xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-xs font-bold text-teal-600 mb-3 uppercase tracking-[0.2em]">Common Questions</p>
        <h2 class="text-4xl font-extrabold">Frequently Asked Questions</h2>
      </div>
      <div class="space-y-4">
        {[
          { q: 'What does an AI consultant do?', a: 'An AI consultant helps businesses identify where artificial intelligence can add value, designs a strategy to implement it, and either builds the solution or oversees its development. At Agentic AI Associates, we cover the full lifecycle: from initial AI readiness audit through to deployment, team training, and ongoing optimisation.' },
          { q: 'How much does AI consultancy cost in the UK?', a: 'AI consultancy in the UK typically ranges from £5,000 for a focused strategy engagement to £50,000+ for full implementation projects. Costs depend on scope, complexity, and the number of systems involved. We offer a free initial consultation to scope your project and provide a clear, fixed-price proposal.' },
          { q: 'How long does an AI project take?', a: 'A focused AI strategy engagement takes 2-4 weeks. Implementation projects typically deliver first results within 6-8 weeks, with full deployment in 3-6 months. Agentic AI systems with complex workflow automation can take longer depending on integration requirements.' },
          { q: 'Do I need technical expertise to work with you?', a: 'No. We work with business owners, operations directors, and leadership teams who understand their business challenges but not necessarily AI technology. We handle the technical complexity and communicate in plain language throughout.' },
          { q: 'What is agentic AI?', a: 'Agentic AI refers to AI systems that can take sequences of actions autonomously to complete complex, multi-step tasks — rather than simply responding to single prompts. These systems use tools, browse data sources, make decisions, and loop back to check their work, enabling automation of workflows that previously required human judgment.' },
        ].map(({q, a}) => (
          <details class="card-animated-border p-6 group">
            <summary class="font-semibold text-lg cursor-pointer list-none flex items-center justify-between">
              {q}
              <svg class="w-5 h-5 text-teal-500 flex-shrink-0 ml-4 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p class="mt-4 text-slate-500 leading-relaxed">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner
    headline="Ready to talk about your AI ambitions?"
    text="Book a free 30-minute consultation. We'll discuss your challenges, explore the possibilities, and give you an honest assessment of where AI can help — no sales pitch."
    buttonText="Book a Free Consultation"
    buttonHref="/contact/"
    secondaryText="Explore Our Services"
    secondaryHref="/services/"
  />
</BaseLayout>
