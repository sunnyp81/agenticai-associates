---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTABanner from '@/components/CTABanner.astro';
import { buildWebSiteSchema, buildOrganizationSchema, buildDefinedTermSchema, buildSpeakableSchema } from '@/lib/schema';
import { siteConfig } from '@/data/site-config';
import { getResults } from '@/lib/page-factory';

const results = getResults();

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What does an AI consultant do?',
      acceptedAnswer: { '@type': 'Answer', text: 'An AI consultant helps businesses identify where artificial intelligence can add value, designs a strategy to implement it, and builds the solution. At Agentic AI Associates, we cover the full lifecycle: from AI readiness assessment through to deployment, team training, and ongoing optimisation.' },
    },
    {
      '@type': 'Question',
      name: 'How much does AI consultancy cost in the UK?',
      acceptedAnswer: { '@type': 'Answer', text: 'Our engagement runs in three fixed phases. Phase 1 Diagnostic is £6,500 for a three-week operational review that delivers a board-ready AI roadmap. Phase 2 Build runs at £850 per day for embedded delivery of the prioritised workflow, typically three to six months. Phase 3 Retain is a £10,000 per month advisory retainer for governance and scale-out, one day per week. No hourly advisory, no hidden fees.' },
    },
    {
      '@type': 'Question',
      name: 'How long does an AI project take?',
      acceptedAnswer: { '@type': 'Answer', text: 'Phase 1 Diagnostic is three weeks start to board-ready roadmap. Phase 2 Build is three to six months with a working system inside the first 90 days. Phase 3 Retain is rolling three-month retainer terms.' },
    },
    {
      '@type': 'Question',
      name: 'Do I need technical expertise to work with you?',
      acceptedAnswer: { '@type': 'Answer', text: 'No. We work with business owners, operations directors, and leadership teams who understand their business challenges but not necessarily AI technology. We handle the technical complexity and communicate in plain language.' },
    },
    {
      '@type': 'Question',
      name: 'What is agentic AI?',
      acceptedAnswer: { '@type': 'Answer', text: 'Agentic AI refers to AI systems that take sequences of actions autonomously to complete complex, multi-step tasks — rather than simply responding to single prompts. These systems use tools, browse data sources, make decisions, and check their work, enabling automation of workflows that previously required human judgment.' },
    },
  ],
};

const definedTermAgentic = buildDefinedTermSchema({
  term: 'Agentic AI',
  definition: 'A class of AI systems that take sequences of actions autonomously to complete multi-step business tasks — using tools, querying data, making decisions, and verifying their own work — rather than waiting for a human prompt at every step.',
  url: `${siteConfig.url}/#agentic-ai`,
  sameAs: ['https://en.wikipedia.org/wiki/Intelligent_agent'],
});

const definedTermAssessment = buildDefinedTermSchema({
  term: 'AI Readiness Assessment',
  definition: 'A 3-week fixed-fee diagnostic (£6,500) that audits a business\'s data, processes, team capability, and governance posture, then delivers a ranked roadmap of the highest-ROI AI use cases.',
  url: `${siteConfig.url}/what-we-do/ai-readiness-assessment/#defined-term`,
});

const speakableHome = buildSpeakableSchema({
  url: siteConfig.url + '/',
  cssSelectors: ['.hero-headline', '.hero-sub', '.phase-card .phase-price'],
});

const offerCatalogSchema = {
  '@context': 'https://schema.org',
  '@type': 'OfferCatalog',
  '@id': `${siteConfig.url}/#offer-catalog`,
  name: 'Agentic AI Associates Engagement Phases',
  provider: { '@id': `${siteConfig.url}/#organization` },
  itemListElement: [
    {
      '@type': 'Offer',
      '@id': `${siteConfig.url}/#offer-phase1`,
      name: 'Phase 1 — Diagnostic',
      description: '3-week fixed-fee operational review delivering a board-ready AI roadmap. Includes data, processes, team capability, and governance posture audit.',
      category: 'AI Consultancy',
      url: `${siteConfig.url}/get-started/`,
      priceSpecification: { '@type': 'PriceSpecification', price: 6500, priceCurrency: 'GBP', valueAddedTaxIncluded: false },
      eligibleDuration: { '@type': 'QuantitativeValue', value: 3, unitCode: 'WEE' },
      areaServed: { '@type': 'Country', name: 'United Kingdom' },
      availability: 'https://schema.org/InStock',
    },
    {
      '@type': 'Offer',
      '@id': `${siteConfig.url}/#offer-phase2`,
      name: 'Phase 2 — Build',
      description: 'Embedded delivery of the priority workflow scoped in Phase 1, shipped and measurable inside 90 days. Time-and-materials or milestone fixed-fee.',
      category: 'AI Consultancy',
      url: `${siteConfig.url}/get-started/`,
      priceSpecification: { '@type': 'UnitPriceSpecification', price: 850, priceCurrency: 'GBP', unitCode: 'DAY', referenceQuantity: { '@type': 'QuantitativeValue', value: 1, unitCode: 'DAY' }, valueAddedTaxIncluded: false },
      areaServed: { '@type': 'Country', name: 'United Kingdom' },
      availability: 'https://schema.org/InStock',
    },
    {
      '@type': 'Offer',
      '@id': `${siteConfig.url}/#offer-phase3`,
      name: 'Phase 3 — Retain',
      description: 'Founder-led advisory, governance, and scale-out oversight. One day per week. Rolling three-month terms.',
      category: 'AI Consultancy',
      url: `${siteConfig.url}/get-started/`,
      priceSpecification: { '@type': 'UnitPriceSpecification', price: 10000, priceCurrency: 'GBP', unitCode: 'MON', referenceQuantity: { '@type': 'QuantitativeValue', value: 1, unitCode: 'MON' }, valueAddedTaxIncluded: false },
      areaServed: { '@type': 'Country', name: 'United Kingdom' },
      availability: 'https://schema.org/InStock',
    },
  ],
};

const schemas = [
  buildWebSiteSchema(),
  buildOrganizationSchema(),
  offerCatalogSchema,
  faqSchema,
  definedTermAgentic,
  definedTermAssessment,
  speakableHome,
];

const services = [
  { tag: 'ASSESS-01', title: 'AI Readiness Assessment', description: 'Fixed-fee audit of your data, processes, and team. Walk away with a prioritised AI roadmap and clear ROI ranges.', href: '/what-we-do/ai-readiness-assessment/', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
  { tag: 'BUILD-02', title: 'Agentic AI Systems', description: 'Autonomous AI agents that handle complex workflows end to end. We design, build, and deploy them.', href: '/what-we-do/agentic-ai/', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
  { tag: 'AUTO-03', title: 'AI Automation', description: 'Intelligent automation for document processing, onboarding, data entry, and workflow orchestration.', href: '/what-we-do/ai-automation/', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
  { tag: 'GEN-04', title: 'Generative AI & LLMs', description: 'RAG systems, content pipelines, and LLM integration. The right model for each use case.', href: '/what-we-do/generative-ai/', icon: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z' },
  { tag: 'GOV-05', title: 'AI Governance', description: 'Compliance frameworks, bias audits, and risk management for UK regulatory requirements.', href: '/what-we-do/ai-governance/', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
  { tag: 'STRAT-06', title: 'AI Strategy & Roadmaps', description: 'From opportunity mapping to board-ready business cases. Strategy that leads to action.', href: '/what-we-do/ai-strategy/', icon: 'M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2z' },
];

const industries = [
  { code: 'IND-01', title: 'Healthcare', blurb: 'Clinical AI, NHS compliance, and patient data automation. We understand CQC requirements and build within them.', tags: ['CQC', 'NHS', 'GDPR', 'HL7'] },
  { code: 'IND-02', title: 'Legal', blurb: 'Document review, SRA-compliant AI, and matter automation. Trusted by UK law firms.', tags: ['SRA', 'AML', 'E-Discovery', 'PII'] },
  { code: 'IND-03', title: 'Finance', blurb: 'FCA-compliant AI, fraud detection, and automated reporting for financial services.', tags: ['FCA', 'MiFID II', 'AML', 'RegTech'] },
  { code: 'IND-04', title: 'Retail', blurb: 'Demand forecasting, personalisation engines, and inventory optimisation for UK retailers.', tags: ['Forecasting', 'Personalisation', 'Ecommerce'] },
  { code: 'IND-05', title: 'Manufacturing', blurb: 'Predictive maintenance, quality control AI, and supply chain intelligence.', tags: ['IoT', 'PdM', 'Quality', 'Supply Chain'] },
  { code: 'IND-06', title: 'Education', blurb: 'Adaptive learning systems, admin automation, and Ofsted-compliant AI for UK schools.', tags: ['Ofsted', 'GDPR', 'LMS', 'Safeguarding'] },
];

const faqs = [
  { q: 'What does an AI consultant do?', a: 'An AI consultant helps businesses identify where artificial intelligence can add value, designs a strategy to implement it, and builds the solution. At Agentic AI Associates, we cover the full lifecycle: from AI readiness assessment through to deployment, team training, and ongoing optimisation.' },
  { q: 'How much does AI consultancy cost in the UK?', a: 'We run three fixed phases: Phase 1 Diagnostic £6,500 for a three-week operational review with a board-ready roadmap; Phase 2 Build £850/day for embedded delivery of the priority workflow (3–6 months); Phase 3 Retain £10,000/month for governance and scale-out (1 day/week). No hourly advisory, no hidden fees.' },
  { q: 'How long does an AI project take?', a: 'Phase 1 Diagnostic — three weeks to a board-ready roadmap. Phase 2 Build — three to six months, with a working system inside the first 90 days. Phase 3 Retain — rolling three-month terms, extendable.' },
  { q: 'Do I need technical expertise to work with you?', a: 'No. We work with business owners, operations directors, and leadership teams who understand their business challenges but not necessarily AI technology. We handle the technical complexity and communicate in plain language.' },
  { q: 'What is agentic AI?', a: 'Agentic AI refers to AI systems that take sequences of actions autonomously to complete complex, multi-step tasks. These systems use tools, browse data sources, make decisions, and check their work — enabling automation of workflows that previously required human judgment.' },
];
---

<BaseLayout
  title="AI Consultancy UK — Agentic AI Associates | Strategy, Implementation & Training"
  description="UK AI consultancy specialising in agentic AI systems, automation, and governance. We build AI that delivers measurable results from week one."
  schema={schemas}
>

  <!-- ─── [00] HERO ─────────────────────────────────────────── -->
  <section class="hero-section">
    <div style="position:absolute;top:-200px;right:-200px;width:min(700px,100vw);height:min(700px,100vw);background:radial-gradient(circle,rgba(0,229,255,0.15),transparent 60%);pointer-events:none;"></div>
    <div style="position:absolute;bottom:-100px;left:-100px;width:500px;height:500px;background:radial-gradient(circle,rgba(0,229,255,0.4),transparent 60%);pointer-events:none;"></div>
    <div class="scan-overlay" aria-hidden="true"></div>

    <div class="container" style="position:relative;">

      <!-- Meta row: condensed on mobile -->
      <div class="hero-meta-row signal-kicker">
        <span><span class="n">▸</span> UK_AI_CONSULTANCY</span>
        <span class="hidden sm:inline">FOUNDED 2025</span>
        <span class="hidden sm:inline">PRACTITIONER-LED</span>
        <span class="live-dot ml-auto"><span class="live-dot-pulse"></span>LIVE</span>
      </div>

      <!-- Headline -->
      <h1 class="hero-headline">
        AI systems that deliver<br class="hidden sm:block">
        <span id="tw-target" class="text-glow-bright" style="color:#00E5FF;">from week one.</span><span class="tw-cursor" id="tw-cursor"></span>
      </h1>

      <!-- Sub + CTAs -->
      <p class="hero-sub page-intro">
        <strong style="color:#EDEDEA;font-weight:600;">Agentic AI Associates is a UK consultancy that designs, builds, and operates agentic AI systems</strong> — autonomous software agents that execute multi-step business workflows end-to-end. We replace strategy decks with working systems, founded by practitioners not career consultants.
      </p>
      <p style="font-family:var(--font-mono);font-size:0.75rem;line-height:1.7;letter-spacing:0.02em;color:#6c6c72;margin:-0.5rem 0 1.75rem;max-width:640px;">
        <span class="n" style="color:#00E5FF;">▸</span> We work with UK mid-market B2B — typically £100M–£500M revenue, often PE-backed — when the board wants an AI story this quarter, not next year. Every engagement starts with an <a href="/what-we-do/ai-readiness-assessment/" style="color:#00E5FF;text-decoration:none;border-bottom:1px solid rgba(0,229,255,0.4);">AI Readiness Assessment</a>.
      </p>
      <div class="hero-ctas">
        <a href="/contact/" class="btn-glow">Book a Fit Call →</a>
        <a href="/get-started/" class="btn-outline">See the Diagnostic</a>
      </div>

      <!-- Live agent workflow graph (Signal canonical) -->
      <div class="graph-wrapper" aria-hidden="true">
        <div class="graph-topbar">
          <span style="position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,#00E5FF,#00E5FF,transparent);"></span>
          <span class="live-dot"><span class="live-dot-pulse"></span>AGENT · inbox_triage.v3 · RUNNING</span>
          <span class="graph-path">+12 actions/min</span>
        </div>

        <div class="graph-svg-frame">
        <svg viewBox="0 0 900 400" xmlns="http://www.w3.org/2000/svg" class="graph-svg agent-graph" preserveAspectRatio="xMidYMid meet">
          <defs>
            <pattern id="hg-grid" width="40" height="40" patternUnits="userSpaceOnUse">
              <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#222" stroke-width="0.5"/>
            </pattern>
            <filter id="hg-glow" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur stdDeviation="2.5"/>
            </filter>
          </defs>

          <rect width="900" height="400" fill="url(#hg-grid)" opacity="0.4"/>

          <!-- 8 edges, rest-state rules (matches original C_Signal: stroke=#222, width=1) -->
          <g class="hg-edges">
            <line class="hg-edge-rest" data-i="0" x1="80"  y1="100" x2="280" y2="80" />
            <line class="hg-edge-rest" data-i="1" x1="80"  y1="100" x2="280" y2="220"/>
            <line class="hg-edge-rest" data-i="2" x1="280" y1="80"  x2="460" y2="150"/>
            <line class="hg-edge-rest" data-i="3" x1="280" y1="220" x2="460" y2="150"/>
            <line class="hg-edge-rest" data-i="4" x1="460" y1="150" x2="640" y2="120"/>
            <line class="hg-edge-rest" data-i="5" x1="640" y1="120" x2="640" y2="260"/>
            <line class="hg-edge-rest" data-i="6" x1="640" y1="120" x2="820" y2="180"/>
            <line class="hg-edge-rest" data-i="7" x1="640" y1="260" x2="820" y2="180"/>
          </g>

          <!-- Live trails — full line A→packet, opacity fades 1→0 -->
          <g class="hg-trails">
            <line class="hg-trail" data-i="0" x1="80"  y1="100" x2="80"  y2="100"/>
            <line class="hg-trail" data-i="1" x1="80"  y1="100" x2="80"  y2="100"/>
            <line class="hg-trail" data-i="2" x1="280" y1="80"  x2="280" y2="80" />
            <line class="hg-trail" data-i="3" x1="280" y1="220" x2="280" y2="220"/>
            <line class="hg-trail" data-i="4" x1="460" y1="150" x2="460" y2="150"/>
            <line class="hg-trail" data-i="5" x1="640" y1="120" x2="640" y2="120"/>
            <line class="hg-trail" data-i="6" x1="640" y1="120" x2="640" y2="120"/>
            <line class="hg-trail" data-i="7" x1="640" y1="260" x2="640" y2="260"/>
          </g>

          <!-- Packets — soft Gaussian-blurred halo + crisp core (matches original C_Signal) -->
          <g class="hg-pkts">
            <g class="hg-pkt" data-i="0"><circle r="3" fill="#00E5FF" filter="url(#hg-glow)"/><circle r="2" fill="#00E5FF"/></g>
            <g class="hg-pkt" data-i="1"><circle r="3" fill="#00E5FF" filter="url(#hg-glow)"/><circle r="2" fill="#00E5FF"/></g>
            <g class="hg-pkt" data-i="2"><circle r="3" fill="#00E5FF" filter="url(#hg-glow)"/><circle r="2" fill="#00E5FF"/></g>
            <g class="hg-pkt" data-i="3"><circle r="3" fill="#00E5FF" filter="url(#hg-glow)"/><circle r="2" fill="#00E5FF"/></g>
            <g class="hg-pkt" data-i="4"><circle r="3" fill="#00E5FF" filter="url(#hg-glow)"/><circle r="2" fill="#00E5FF"/></g>
            <g class="hg-pkt" data-i="5"><circle r="3" fill="#00E5FF" filter="url(#hg-glow)"/><circle r="2" fill="#00E5FF"/></g>
            <g class="hg-pkt" data-i="6"><circle r="3" fill="#00E5FF" filter="url(#hg-glow)"/><circle r="2" fill="#00E5FF"/></g>
            <g class="hg-pkt" data-i="7"><circle r="3" fill="#00E5FF" filter="url(#hg-glow)"/><circle r="2" fill="#00E5FF"/></g>
          </g>

          <!-- 7 labelled nodes (INPUT → AGENT/TOOL → AGENT(core) → AGENT/HUMAN → OUTPUT) -->
          <g class="node">
            <rect x="20"  y="80"  width="120" height="40" rx="6" fill="#050507" stroke="#222"/>
            <text x="80"  y="96"  text-anchor="middle" class="n-l">INPUT</text>
            <text x="80"  y="112" text-anchor="middle" class="n-n">Email in</text>
          </g>
          <g class="node node-agent">
            <rect x="220" y="60"  width="120" height="40" rx="6" fill="#050507" stroke="#00E5FF" stroke-width="1.5"/>
            <text x="280" y="76"  text-anchor="middle" class="n-l">AGENT</text>
            <text x="280" y="92"  text-anchor="middle" class="n-n">Triage</text>
          </g>
          <g class="node">
            <rect x="220" y="200" width="120" height="40" rx="6" fill="#050507" stroke="#222"/>
            <text x="280" y="216" text-anchor="middle" class="n-l">TOOL</text>
            <text x="280" y="232" text-anchor="middle" class="n-n">CRM</text>
          </g>
          <g class="node node-agent node-core">
            <rect x="400" y="130" width="120" height="40" rx="6" fill="#050507" stroke="#00E5FF" stroke-width="1.5"/>
            <text x="460" y="146" text-anchor="middle" class="n-l">AGENT</text>
            <text x="460" y="162" text-anchor="middle" class="n-n">Knowledge</text>
          </g>
          <g class="node node-agent">
            <rect x="580" y="100" width="120" height="40" rx="6" fill="#050507" stroke="#00E5FF" stroke-width="1.5"/>
            <text x="640" y="116" text-anchor="middle" class="n-l">AGENT</text>
            <text x="640" y="132" text-anchor="middle" class="n-n">Draft reply</text>
          </g>
          <g class="node">
            <rect x="580" y="240" width="120" height="40" rx="6" fill="#050507" stroke="#222"/>
            <text x="640" y="256" text-anchor="middle" class="n-l">HUMAN</text>
            <text x="640" y="272" text-anchor="middle" class="n-n">Reviewer</text>
          </g>
          <g class="node">
            <rect x="760" y="160" width="120" height="40" rx="6" fill="#050507" stroke="#222"/>
            <text x="820" y="176" text-anchor="middle" class="n-l">OUTPUT</text>
            <text x="820" y="192" text-anchor="middle" class="n-n">Sent</text>
          </g>
        </svg>
        </div>

        <div class="graph-statusbar">
          <span class="gstat"><span style="color:#00E5FF;">●</span> 4 agents active</span>
          <span class="gstat"><span style="color:#00E5FF;">●</span> evals 96/100</span>
          <span class="gstat"><span style="color:#00E5FF;">●</span> guardrails active</span>
          <span class="gstat" style="margin-left:auto;">latency 94ms ↓</span>
        </div>
      </div>

      <!-- Meta bar: 2×2 on mobile, 4×1 on sm+ -->
      <div class="meta-bar">
        {[
          ['LOCATION', 'London, UK'],
          ['STATUS', 'Q3 Open'],
          ['FOUNDED', '2025'],
          ['GDPR', 'Registered'],
        ].map(([k, v]) => (
          <div class="meta-cell">
            <div class="meta-key">{k}</div>
            <div class="meta-val">{v}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── [01] ENGAGEMENT ───────────────────────────────────── -->
  <section class="sig-section" style="background:#050507;">
    <div class="container">
      <div class="signal-divider">
        <span class="signal-kicker"><span class="n">[01]</span> <span>Engagement</span></span>
        <h2>How does our AI engagement model work?</h2>
        <p style="font-size:1rem;line-height:1.65;color:#8a8a92;margin:1rem 0 0;max-width:640px;">Every engagement opens with a 30-minute fit call. From there, one fixed-fee diagnostic, then embedded build, then ongoing retainer — stepped so you can stop or continue at any phase boundary.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          { n: '01', label: 'Fixed fee · 3 weeks', title: 'Diagnostic', body: 'A structured review of your operations, data, and team capability. You leave with a board-ready AI roadmap, prioritised by ROI and ranked for fit, cost, and risk. No prior commitment to Phase 2.' },
          { n: '02', label: '£850/day · 3–6 months', title: 'Build', body: 'We embed alongside your team to deliver the highest-priority workflow — scoped, shipped, and measurable inside 90 days. Time-and-materials or milestone fixed-fee. PI/PL cover in place.' },
          { n: '03', label: '£10k/month · 1 day/week', title: 'Retain', body: 'Governance, measurement, and roll-out oversight as you scale AI across the business. Rolling three-month terms, extendable. Rates held for twelve months from signature.' },
        ].map((step, i) => (
          <div class="signal-card" style={i === 0 ? 'background:linear-gradient(155deg,rgba(0,229,255,0.08),transparent 60%);' : ''}>
            <div class="step-num text-glow">{step.n}</div>
            <span class="mono-tag" style="margin-bottom:0.875rem;">{step.label}</span>
            <h3 class="step-title">{step.title}</h3>
            <p class="step-body">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── [02] CAPABILITIES ─────────────────────────────────── -->
  <section class="sig-section sig-section-alt">
    <div class="container">
      <div class="signal-divider">
        <span class="signal-kicker"><span class="n">[02]</span> <span>Capabilities</span></span>
        <h2>What AI services do we offer?</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {services.map((svc) => (
          <a href={svc.href} class="signal-card svc-card">
            <div class="svc-card-top">
              <div class="svc-icon">
                <svg width="20" height="20" fill="none" stroke="#00E5FF" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={svc.icon}/>
                </svg>
              </div>
              <span class="svc-arrow">→</span>
            </div>
