    .lg\:grid-cols-3 { grid-template-columns: repeat(3, 1fr); }
  }

  /* SVG graph node animations */
  @keyframes node-a { 0%,100%{opacity:.4;} 50%{opacity:.9;} }
  @keyframes node-b { 0%,100%{opacity:.6;} 50%{opacity:1;} }
  @keyframes node-main { 0%,100%{opacity:.8;} 50%{opacity:1; filter:drop-shadow(0 0 12px #5eead4);} }
  @keyframes node-c { 0%,100%{opacity:.5;} 50%{opacity:.9;} }
  @keyframes node-d { 0%,100%{opacity:.6;} 50%{opacity:1;} }
  @keyframes node-e { 0%,100%{opacity:.3;} 50%{opacity:.7;} }
  @keyframes node-f { 0%,100%{opacity:.3;} 50%{opacity:.6;} }
  @keyframes ring-a { 0%,100%{opacity:.2; r:9;} 50%{opacity:.5; r:13;} }
  @keyframes ring-b { 0%,100%{opacity:.2; r:12;} 50%{opacity:.5; r:17;} }
  @keyframes ring-main { 0%,100%{opacity:.25; r:15;} 50%{opacity:.6; r:22;} }
  @keyframes ring-c { 0%,100%{opacity:.15; r:11;} 50%{opacity:.4; r:16;} }
  @keyframes ring-d { 0%,100%{opacity:.15; r:12;} 50%{opacity:.4; r:17;} }

  /* Data packets */
  @keyframes pkt1 { 0%{offset-distance:0%;opacity:0;} 8%{opacity:1;} 92%{opacity:1;} 100%{offset-distance:100%;opacity:0;} }
  @keyframes pkt2 { 0%{offset-distance:0%;opacity:0;} 8%{opacity:1;} 92%{opacity:1;} 100%{offset-distance:100%;opacity:0;} }
  @keyframes pkt3 { 0%{offset-distance:0%;opacity:0;} 8%{opacity:1;} 92%{opacity:1;} 100%{offset-distance:100%;opacity:0;} }
  @keyframes pkt4 { 0%{offset-distance:0%;opacity:0;} 8%{opacity:1;} 92%{opacity:1;} 100%{offset-distance:100%;opacity:0;} }
</style>

<script>
  // Typewriter cycling phrases
  const phrases = ['from week one.', 'that ship.', 'that stick.', 'that pay back.'];
  const target = document.getElementById('tw-target');
  let idx = 0;
  let charIdx = 0;
  let deleting = false;
  let paused = false;

  function tick() {
    if (!target) return;
    const phrase = phrases[idx];

    if (paused) {
      paused = false;
      setTimeout(tick, 1200);
      return;
    }

    if (!deleting) {
      target.textContent = phrase.slice(0, charIdx + 1);
      charIdx++;
      if (charIdx === phrase.length) {
        deleting = true;
        paused = true;
      }
    } else {
      target.textContent = phrase.slice(0, charIdx - 1);
      charIdx--;
      if (charIdx === 0) {
        deleting = false;
        idx = (idx + 1) % phrases.length;
      }
    }

    setTimeout(tick, deleting ? 45 : 85);
  }

  // Start after a short delay
  setTimeout(tick, 1500);

  // Waveform bars generator
  function buildWaveform(id: string, bars: number) {
    const container = document.getElementById(id);
    if (!container) return;
    for (let i = 0; i < bars; i++) {
      const bar = document.createElement('div');
      bar.className = 'wb';
      const delay = (Math.random() * 2).toFixed(2);
      const duration = (0.6 + Math.random() * 1.4).toFixed(2);
      bar.style.cssText = `animation:wave-bar ${duration}s ease-in-out infinite ${delay}s;`;
      container.appendChild(bar);
    }
  }

  buildWaveform('wf-top', 120);
  buildWaveform('wf-bottom', 100);

  // Industry tabs
  const tabs = document.querySelectorAll<HTMLButtonElement>('.industry-tab');
  const panels = document.querySelectorAll<HTMLElement>('[id^="ind-panel-"]');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const i = tab.dataset.ind;
      tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      panels.forEach(p => { p.style.display = 'none'; });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      const panel = document.getElementById(`ind-panel-${i}`);
      if (panel) panel.style.display = 'block';
    });
  });
</script>
