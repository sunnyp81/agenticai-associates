    font-size: 1.25rem;
    color: #6c6c72;
    flex-shrink: 0;
    transition: transform 0.2s, color 0.2s;
    margin-top: 2px;
  }
  details.signal-faq[open] .faq-icon { transform: rotate(45deg); color: #00E5FF; }
  .faq-answer {
    padding: 0 0.25rem 1.25rem 3.25rem;
    max-width: 780px;
  }
  .faq-answer p { margin: 0; font-size: 0.9375rem; line-height: 1.75; color: #6c6c72; }

  /* ── SHARED ─────────────────────────────────────────────── */
  .section-cta { text-align: center; margin-top: 2rem; }
  .signal-divider h2 { font-size: clamp(1.5rem, 4vw, 2.75rem); }

  /* ── GRAPH NODE ANIMATIONS ───────────────────────────────── */
  @keyframes nd-a { 0%,100%{opacity:.4}50%{opacity:.9} }
  @keyframes nd-b { 0%,100%{opacity:.6}50%{opacity:1} }
  @keyframes nd-main { 0%,100%{opacity:.8}50%{opacity:1;filter:drop-shadow(0 0 12px #00E5FF)} }
  @keyframes nd-c { 0%,100%{opacity:.5}50%{opacity:.9} }
  @keyframes nd-d { 0%,100%{opacity:.6}50%{opacity:1} }
  @keyframes nd-e { 0%,100%{opacity:.3}50%{opacity:.7} }
  @keyframes nd-f { 0%,100%{opacity:.3}50%{opacity:.6} }
  @keyframes rg-a { 0%,100%{opacity:.2;r:9}50%{opacity:.5;r:13} }
  @keyframes rg-b { 0%,100%{opacity:.2;r:12}50%{opacity:.5;r:17} }
  @keyframes rg-main { 0%,100%{opacity:.25;r:15}50%{opacity:.6;r:22} }
  @keyframes rg-c { 0%,100%{opacity:.15;r:11}50%{opacity:.4;r:16} }
  @keyframes rg-d { 0%,100%{opacity:.15;r:12}50%{opacity:.4;r:17} }
  @keyframes pkt1 { 0%{offset-distance:0%;opacity:0}8%{opacity:1}92%{opacity:1}100%{offset-distance:100%;opacity:0} }
  @keyframes pkt2 { 0%{offset-distance:0%;opacity:0}8%{opacity:1}92%{opacity:1}100%{offset-distance:100%;opacity:0} }
  @keyframes pkt3 { 0%{offset-distance:0%;opacity:0}8%{opacity:1}92%{opacity:1}100%{offset-distance:100%;opacity:0} }
  @keyframes pkt4 { 0%{offset-distance:0%;opacity:0}8%{opacity:1}92%{opacity:1}100%{offset-distance:100%;opacity:0} }
</style>

<script>
  // Typewriter
  const phrases = ['from week one.', 'that ship.', 'that stick.', 'that pay back.'];
  const target = document.getElementById('tw-target');
  let idx = 0, charIdx = 0, deleting = false, paused = false;
  function tick() {
    if (!target) return;
    const phrase = phrases[idx];
    if (paused) { paused = false; setTimeout(tick, 1200); return; }
    if (!deleting) {
      target.textContent = phrase.slice(0, charIdx + 1);
      charIdx++;
      if (charIdx === phrase.length) { deleting = true; paused = true; }
    } else {
      target.textContent = phrase.slice(0, charIdx - 1);
      charIdx--;
      if (charIdx === 0) { deleting = false; idx = (idx + 1) % phrases.length; }
    }
    setTimeout(tick, deleting ? 45 : 85);
  }
  setTimeout(tick, 1500);

  // Waveform bars — fewer on mobile
  function buildWaveform(id: string) {
    const container = document.getElementById(id);
    if (!container) return;
    const bars = window.innerWidth < 640 ? 40 : 100;
    for (let i = 0; i < bars; i++) {
      const bar = document.createElement('div');
      bar.className = 'wb';
      bar.style.cssText = `animation:wave-bar ${(0.6 + Math.random() * 1.4).toFixed(2)}s ease-in-out infinite ${(Math.random() * 2).toFixed(2)}s;`;
      container.appendChild(bar);
    }
  }
  buildWaveform('wf-top');
  buildWaveform('wf-bottom');

  // Industry tabs — unified handler for both pill and sidebar tabs
  function setupTabs() {
    const allTabs = document.querySelectorAll<HTMLButtonElement>('[data-ind]');
    const panels = document.querySelectorAll<HTMLElement>('[id^="ind-panel-"]');

    allTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const i = tab.dataset.ind!;
        // Update all tabs (both pill + sidebar) with same index
        allTabs.forEach(t => {
          t.classList.toggle('active', t.dataset.ind === i);
          t.setAttribute('aria-selected', t.dataset.ind === i ? 'true' : 'false');
        });
        // Show matching panel only (on md+)
        if (window.innerWidth >= 768) {
          panels.forEach(p => { p.style.display = p.id === `ind-panel-${i}` ? 'block' : 'none'; });
        }
      });
    });
  }
  setupTabs();

  // ── Homepage agent-graph animation (rAF, matches original SignalLiveGraph) ──
  // Period 2s per edge, 8 edges with 0.25s stagger → 4 packets in flight at once.
  // Trail = line A → packet, opacity 1 − p (fades toward target).
  (() => {
    const reduce = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches;
    const root = document.querySelector('.agent-graph');
    if (!root || reduce) return;
    const EDGES = [
      [80, 100, 280, 80],
      [80, 100, 280, 220],
      [280, 80,  460, 150],
      [280, 220, 460, 150],
      [460, 150, 640, 120],
      [640, 120, 640, 260],
      [640, 120, 820, 180],
      [640, 260, 820, 180],
    ];
    const trails = root.querySelectorAll('.hg-trail');
    const pkts   = root.querySelectorAll('.hg-pkt');
    // Matches original C_Signal: 120-frame period @60fps = 2s, 18-frame stagger = 0.3s
    const PERIOD = 2.0, STAGGER = 0.3;
    let start = 0, rafId = 0;

    const tick = (ts) => {
      if (!start) start = ts;
      const t = (ts - start) / 1000;
      for (let i = 0; i < EDGES.length; i++) {
        const phase = ((t + i * STAGGER) % PERIOD) / PERIOD;
        const active = phase < 0.5;
        const trail = trails[i], pkt = pkts[i];
        if (!trail || !pkt) continue;
        if (active) {
          const p = phase * 2; // 0..1 traversal
          const [x1, y1, x2, y2] = EDGES[i];
          const px = x1 + (x2 - x1) * p;
          const py = y1 + (y2 - y1) * p;
          trail.setAttribute('x2', px.toFixed(2));
          trail.setAttribute('y2', py.toFixed(2));
          trail.style.opacity = String(1 - p);
          pkt.setAttribute('transform', `translate(${px.toFixed(2)} ${py.toFixed(2)})`);
          pkt.style.opacity = '1';
        } else {
          trail.style.opacity = '0';
          pkt.style.opacity = '0';
        }
      }
      rafId = requestAnimationFrame(tick);
    };
    rafId = requestAnimationFrame(tick);

    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) { if (!rafId) rafId = requestAnimationFrame(tick); }
        else { cancelAnimationFrame(rafId); rafId = 0; }
      });
    }, { threshold: 0 });
    io.observe(root);
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) { cancelAnimationFrame(rafId); rafId = 0; }
      else if (!rafId) rafId = requestAnimationFrame(tick);
    });
  })();

  // CSS translateY uses CSS px, not SVG user units — at mobile scale (~0.37×) the old
  // -12px was moving text ~32 SVG units instead of 12, pushing labels above their boxes.
  // Fix: shift the y attribute by exactly 12 SVG user units when labels are hidden.
  if (window.innerWidth < 768) {
    document.querySelectorAll<SVGTextElement>('.agent-graph .n-n').forEach(el => {
      const y = parseFloat(el.getAttribute('y') || '0');
      el.setAttribute('y', String(y - 12));
    });
  }
</script>
