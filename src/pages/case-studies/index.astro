---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BreadcrumbNav from '@/components/BreadcrumbNav.astro';
import CTABanner from '@/components/CTABanner.astro';

const caseStudies = [
  {
    title: 'Automated Document Processing for a Legal Firm',
    industry: 'Legal',
    result: '70% reduction in manual review time',
    description: 'We built an AI-powered document analysis system that reads, categorises, and extracts key clauses from legal contracts. The firm now processes contracts in minutes, not hours.',
    tags: ['Generative AI', 'Automation', 'Legal'],
  },
  {
    title: 'Demand Forecasting for a UK Retailer',
    industry: 'Retail',
    result: '23% improvement in forecast accuracy',
    description: 'We deployed a machine learning model that predicts weekly demand by product and location. The retailer reduced stockouts by 35% and cut overstock waste significantly.',
    tags: ['Forecasting', 'Data & AI', 'Retail'],
  },
  {
    title: 'AI Chatbot for a Healthcare Provider',
    industry: 'Healthcare',
    result: '40% fewer routine calls to reception',
    description: 'We designed and deployed a conversational AI assistant that handles appointment bookings, FAQs, and prescription queries. Staff now focus on patient care, not phone calls.',
    tags: ['Conversational AI', 'Healthcare', 'Implementation'],
  },
];
---

<BaseLayout
  title="AI Case Studies — Real Results from AI Consultancy | Agentic AI Associates"
  description="See how we've helped UK businesses implement AI solutions. Real case studies with measurable results across healthcare, legal, retail, and more."
>
  <!-- Hero -->
  <section class="bg-[var(--color-hero-bg)] text-[var(--color-hero-text)] section">
    <div class="container">
      <BreadcrumbNav items={[{ label: 'Case Studies', href: '/case-studies/' }]} />
      <h1 class="text-white max-w-3xl">Case Studies</h1>
      <p class="text-lg text-slate-300 mt-4 max-w-2xl leading-relaxed">Real projects. Real results. Here's what happens when AI strategy meets proper execution.</p>
    </div>
  </section>

  <div class="container section">
    <div class="space-y-8 max-w-4xl mx-auto">
      {caseStudies.map((study) => (
        <article class="card-animated-border p-8 md:p-10">
          <div class="flex flex-wrap gap-2 mb-5">
            {study.tags.map((tag) => (
              <span class="text-xs font-semibold px-3 py-1 rounded-full" style="background: rgba(13,148,136,0.1); color: #0d9488;">{tag}</span>
            ))}
          </div>
          <h2 class="text-2xl font-bold mb-3">{study.title}</h2>
          <p class="text-slate-500 leading-relaxed mb-6 text-base">{study.description}</p>
          <div class="flex items-center gap-3 pt-5 border-t border-slate-100">
            <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0" style="background: rgba(5,150,105,0.1);">
              <svg class="w-4 h-4" style="color: #059669;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <span class="font-semibold text-sm" style="color: #059669;">{study.result}</span>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-16 max-w-4xl mx-auto">
      <div class="relative overflow-hidden rounded-2xl p-10 text-center" style="background: #080f1e;">
        <div class="aurora-blob w-64 h-64 top-[-30px] right-0" style="background: #0d9488;"></div>
        <div class="dot-grid absolute inset-0 opacity-[0.06]"></div>
        <div class="relative">
          <p class="text-xs font-bold uppercase tracking-[0.2em] mb-3" style="color: #5eead4;">Your Business Could Be Next</p>
          <h2 class="text-white text-2xl font-bold mb-3">Want results like these?</h2>
          <p class="text-slate-300 mb-6 max-w-lg mx-auto">Book a free 30-minute consultation. We'll tell you honestly whether AI can deliver measurable results for your specific challenges.</p>
          <a href="/contact/" class="btn-glow">Book a Free Consultation</a>
        </div>
      </div>
    </div>
  </div>

  <CTABanner
    headline="Want Results Like These?"
    text="Book a free consultation and let's discuss what AI can do for your business."
  />
</BaseLayout>
