---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BreadcrumbNav from '@/components/BreadcrumbNav.astro';
import { siteConfig } from '@/data/site-config';
---

<BaseLayout
  title="Terms of Service — Agentic AI Associates"
  description="Terms of service for using the Agentic AI Associates website. Read our terms and conditions."
>
  <section class="bg-[var(--color-hero-bg)] text-[var(--color-hero-text)] section-sm">
    <div class="container">
      <BreadcrumbNav items={[{ label: 'Terms of Service', href: '/terms/' }]} />
      <h1 class="text-white">Terms of Service</h1>
      <p class="text-sm text-slate-400 mt-2">Last updated: April 2026</p>
    </div>
  </section>

  <div class="container section-sm">
    <div class="prose max-w-3xl">
      <h2>1. Introduction</h2>
      <p>These terms govern your use of the {siteConfig.name} website at {siteConfig.url}. By using this website, you agree to these terms.</p>

      <h2>2. Services</h2>
      <p>{siteConfig.name} provides AI consultancy services including strategy, implementation, training, and advisory. Specific terms for individual engagements are set out in separate project agreements.</p>

      <h2>3. Website Content</h2>
      <p>The content on this website is provided for general information purposes. While we make every effort to keep information accurate and up to date, we make no guarantees about the completeness or reliability of any content.</p>
      <p>The information on this site does not constitute professional advice. For advice specific to your situation, please <a href="/contact/">contact us</a>.</p>

      <h2>4. Intellectual Property</h2>
      <p>All content on this website — including text, graphics, logos, and design — is the property of {siteConfig.name} and is protected by UK copyright law. You may not reproduce, distribute, or republish content without our written permission.</p>

      <h2>5. Third-Party Links</h2>
      <p>This website may contain links to third-party sites. We are not responsible for the content or privacy practices of those sites.</p>

      <h2>6. Limitation of Liability</h2>
      <p>{siteConfig.name} will not be liable for any indirect, incidental, or consequential damages arising from your use of this website or our services, except where liability cannot be excluded by law.</p>

      <h2>7. Governing Law</h2>
      <p>These terms are governed by the laws of England and Wales. Any disputes will be subject to the exclusive jurisdiction of the courts of England and Wales.</p>

      <h2>8. Changes</h2>
      <p>We may update these terms at any time. Continued use of the website after changes constitutes acceptance of the new terms.</p>

      <h2>9. Contact</h2>
      <p>Questions about these terms? Email <a href={`mailto:${siteConfig.contact.email}`}>{siteConfig.contact.email}</a>.</p>
    </div>
  </div>
</BaseLayout>
