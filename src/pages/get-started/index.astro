---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BreadcrumbNav from '@/components/BreadcrumbNav.astro';
import FAQ from '@/components/FAQ.astro';
import CTABanner from '@/components/CTABanner.astro';
import HeroSignal from '@/components/HeroSignal.astro';
import { buildFAQSchema, buildServiceSchema } from '@/lib/schema';
import { siteConfig } from '@/data/site-config';

const faqs = [
  { question: 'How much does the Phase 1 Diagnostic cost?', answer: 'Phase 1 Diagnostic is a fixed fee of £6,500 for a three-week engagement, covering operational review, opportunity prioritisation, and a board-ready AI roadmap. No hidden costs. Rate held for twelve months from signature.' },
  { question: 'What happens after the Diagnostic?', answer: 'You receive the prioritised roadmap plus a board-ready business case with investment ranges and expected returns per workflow. Phase 2 Build is contracted separately if you decide to proceed — there is no prior commitment from either side.' },
  { question: 'How is Phase 2 Build priced?', answer: 'Phase 2 Build is embedded delivery of the priority workflow, charged at £850 per day on a time-and-materials basis or as a milestone fixed-fee. Typical engagements run 3–6 months with a working system delivered inside the first 90 days.' },
  { question: 'What does Phase 3 Retain cover?', answer: 'Phase 3 is a £10,000 per month retainer — one day per week of founder-led advisory, governance, and scale-out oversight as you extend AI across the business. Rolling three-month terms, extendable.' },
  { question: 'Do you work with small businesses?', answer: 'We focus on UK mid-market B2B — typically £100M–£500M in revenue, often PE-backed. If that is not you, we are not the right fit, and we will tell you so on the fit call rather than waste either side\'s time.' },
];

const faqSchema = buildFAQSchema(faqs);

const assessmentSchema = buildServiceSchema({
  name: 'AI Readiness Assessment',
  description: 'Fixed-fee AI readiness assessment for UK businesses. We audit your data, processes, and team capability, then deliver a prioritised roadmap with clear ROI projections.',
  url: `${siteConfig.url}/get-started/`,
});

const schemas = [assessmentSchema, ...(faqSchema ? [faqSchema] : [])];
---

<BaseLayout
  title="Get Started — Phase 1 Diagnostic | Agentic AI Associates"
  description="Every engagement starts with the Phase 1 Diagnostic — £6,500 fixed fee, three weeks, board-ready AI roadmap. Then Phase 2 Build at £850/day, Phase 3 Retain at £10k/month."
  schema={schemas}
>
  <!-- Hero -->
  <section class="bg-[var(--color-hero-bg)] text-[var(--color-hero-text)] section relative overflow-hidden">
    <HeroSignal variant="network" seed="get-started" />
    <div class="container relative">
      <BreadcrumbNav items={[{ label: 'Get Started', href: '/get-started/' }]} />
      <h1 class="text-white max-w-3xl">Get Started</h1>
      <p class="text-lg text-slate-300 mt-4 max-w-2xl leading-relaxed">Every engagement begins with understanding your business. No sales pitch — just an honest assessment of where AI can help.</p>
    </div>
  </section>

  <div class="container section-sm">
    <!-- Entry point: Phase 1 Diagnostic -->
    <div class="max-w-4xl mx-auto">
      <div class="card border-[var(--color-accent)] border-2 p-8 md:p-10">
        <div class="flex items-start gap-4 mb-6">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(13,148,136,0.1);">
            <svg class="w-6 h-6" style="color: #0d9488;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <p class="text-xs font-mono tracking-widest uppercase" style="color: #0d9488;">Phase 01</p>
            <h2 class="text-2xl font-bold mb-1">Diagnostic</h2>
            <p class="text-sm text-[var(--color-text-muted)]"><strong>£6,500 fixed fee</strong> &middot; 3 weeks &middot; No commitment to Phase 2</p>
          </div>
        </div>

        <p class="text-[var(--color-text-muted)] leading-relaxed mb-6">A structured review of your operations, data, and team capability. You leave with a board-ready AI roadmap — prioritised by ROI, ranked for fit, cost, and risk — plus an investment-sized business case for the phase that comes next.</p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
          {[
            'Operational workflow review',
            'AI opportunity scoring matrix',
            'Technology + data gap analysis',
            'Team capability audit',
            'Prioritised 12-month roadmap',
            'Board-ready business case',
          ].map(item => (
            <div class="flex gap-2 text-sm">
              <span class="text-[var(--color-success)] flex-shrink-0">&#10003;</span>
              <span>{item}</span>
            </div>
          ))}
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact/" class="btn-glow">
            Book a Fit Call
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="/what-we-do/ai-readiness-assessment/" class="btn btn-outline">Read the Diagnostic Brief</a>
        </div>
      </div>

      <!-- Phases 2 + 3 -->
      <div class="mt-16">
        <h2 class="text-center mb-3">After the Diagnostic</h2>
        <p class="text-center text-sm text-[var(--color-text-muted)] mb-10 max-w-2xl mx-auto leading-relaxed">Phase 2 and Phase 3 are contracted separately, on board approval. Rates are held for twelve months from Phase 1 signature.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {[
            { step: '02', title: 'Build', desc: 'We embed alongside your team to deliver the priority workflow scoped in Phase 1 — shipped, measurable, running inside 90 days. PI/PL cover, DPIA, and governance in place before go-live.', range: '£850/day · 3–6 months' },
            { step: '03', title: 'Retain', desc: 'Founder-led advisory, governance, and scale-out oversight as you extend AI across the business. One day per week. Rolling three-month terms, extendable.', range: '£10,000/month · 1 day/week' },
          ].map(item => (
            <div class="text-center md:text-left">
              <p class="text-xs font-mono tracking-widest uppercase mb-2" style="color: #0d9488;">Phase {item.step}</p>
              <h3 class="text-xl font-semibold mb-2">{item.title}</h3>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-3">{item.desc}</p>
              <p class="text-sm font-semibold text-[var(--color-accent)]">{item.range}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Not the right fit -->
      <div class="mt-12 text-center max-w-2xl mx-auto">
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
          <strong class="text-[var(--color-text)]">Not our focus:</strong> we don\'t offer hourly advisory, small-business packages, or PoC sandboxes. If that\'s the shape of engagement you need, we\'ll say so on the fit call.
        </p>
      </div>
    </div>
  </div>

  <div class="container">
    <FAQ faqs={faqs} heading="Common Questions" />
  </div>

  <CTABanner
    headline="Every engagement starts with a 30-minute fit call."
    text="Tell us what you're working on. We'll confirm whether Phase 1 Diagnostic is the right fit — and if it isn't, we'll say so."
    buttonText="Book a Fit Call"
    buttonHref="/contact/"
  />
</BaseLayout>
