---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BreadcrumbNav from '@/components/BreadcrumbNav.astro';
import CTABanner from '@/components/CTABanner.astro';
import HeroSignal from '@/components/HeroSignal.astro';
import { buildOrganizationSchema, buildPersonSchema, buildFAQSchema, buildSpeakableSchema } from '@/lib/schema';
import { siteConfig } from '@/data/site-config';

const aboutFaqs = [
  {
    question: 'Who founded Agentic AI Associates?',
    answer: 'Sunny Patel founded Agentic AI Associates in 2026. Sunny\'s background is in data engineering, applied AI systems, and operational workflow design. He built this site personally, ranked it on Google, and generated an enterprise lead within the first week of launch — the same speed and rigour we bring to client work.',
  },
  {
    question: 'What is Sunny Patel\'s technical background?',
    answer: 'Sunny works across Python, LangChain, OpenAI, Anthropic Claude, Hugging Face, dbt, Astro, and Next.js for the build side. On the workflow automation side: n8n, Temporal, Make, and custom agentic pipelines. Data stack: Postgres, BigQuery, dbt, with production deployment on Cloudflare and Vercel.',
  },
  {
    question: 'Is Agentic AI Associates GDPR compliant?',
    answer: 'Yes. Agentic AI Associates is UK-based, ICO-registered, and operates under fully GDPR-compliant data practices. Professional Indemnity and Public Liability cover is placed before any Phase 2 build engagement begins. We will sign your DPA and complete supplier-onboarding questionnaires as part of the standard engagement process.',
  },
  {
    question: 'What size businesses do you typically work with?',
    answer: 'We focus on UK mid-market B2B — typically £100M to £500M in revenue, often PE-backed — where the board wants an AI story this quarter not next year. We will also engage with smaller businesses where there is a clear fit, but we do not chase enterprise procurement cycles or take on early-stage startups with no commercial validation.',
  },
  {
    question: 'How is Agentic AI Associates different from other AI consultancies?',
    answer: 'Three differences. (1) We build, we do not just advise — every engagement produces working production software. (2) Pricing is fixed and stated up front: £6,500 Phase 1 Diagnostic, £850/day Phase 2 Build, £10k/month Phase 3 Retain. No billable-hour surprises. (3) We specialise in agentic AI specifically — the next wave beyond chatbots and copilots — rather than spreading thin across the full AI surface.',
  },
  {
    question: 'Where is Agentic AI Associates based?',
    answer: 'United Kingdom. We work nationally with UK businesses across England, Scotland, Wales, and Northern Ireland, and we operate remotely with on-site visits as needed for discovery, build kickoff, and stakeholder review sessions.',
  },
];

const aboutFaqSchema = buildFAQSchema(aboutFaqs);
const aboutSpeakable = buildSpeakableSchema({
  url: `${siteConfig.url}/about/`,
  cssSelectors: ['.page-h1', '.page-intro', '.about-founder-lede'],
});

const schemas = [
  buildOrganizationSchema(),
  buildPersonSchema(),
  aboutSpeakable,
  ...(aboutFaqSchema ? [aboutFaqSchema] : []),
];
---

<BaseLayout
  title="About Agentic AI Associates — UK AI Consultancy"
  description="Meet the team behind Agentic AI Associates. We're a UK-based AI consultancy helping businesses adopt intelligent systems that deliver measurable results."
  schema={schemas}
>
  <!-- Hero -->
  <section class="bg-[var(--color-hero-bg)] text-[var(--color-hero-text)] section relative overflow-hidden">
    <HeroSignal variant="network" seed="about" />
    <div class="container relative">
      <BreadcrumbNav items={[{ label: 'About', href: '/about/' }]} />
      <h1 class="page-h1 text-white max-w-3xl">About Agentic AI Associates</h1>
      <p class="page-intro text-lg text-slate-300 mt-4 max-w-2xl leading-relaxed"><strong style="color:#EDEDEA;">Agentic AI Associates is a UK-based AI consultancy founded by Sunny Patel in 2026, specialising in agentic AI systems for mid-market businesses.</strong> We build, deploy, and operate working software — not strategy decks.</p>
    </div>
  </section>

  <div class="container section-sm">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <div class="lg:col-span-2 prose">
        <h2>Who is Agentic AI Associates?</h2>
        <p>Agentic AI Associates is a UK AI consultancy that designs, builds, and operates agentic AI systems for mid-market businesses (typically £100M–£500M revenue, often PE-backed). We work with leadership teams who want measurable AI outcomes inside the current quarter, not a five-year transformation programme.</p>
        <p>Engagements run in three fixed phases: a <a href="/what-we-do/ai-readiness-assessment/">£6,500 AI Readiness Assessment</a> (3 weeks), a <a href="/what-we-do/agentic-ai/">Phase 2 Build</a> at £850 per day for embedded delivery, and a Phase 3 Retain at £10,000 per month for governance and scale-out. Pricing is fixed up front. No billable-hour surprises.</p>

        <h2>What makes Agentic AI Associates different?</h2>
        <ul>
          <li><strong>We build, not just advise.</strong> Most consultancies hand you a strategy document and walk away. We stick around for implementation: we write code, deploy systems, and measure results.</li>
          <li><strong>We speak plain English.</strong> AI is complex enough without consultant-speak. We explain things clearly — short sentences, no jargon.</li>
          <li><strong>We specialise in <a href="/what-we-do/agentic-ai/">agentic AI</a>.</strong> The next wave of AI is not chatbots, it is autonomous agents that handle multi-step workflows end-to-end. We are building these systems today.</li>
          <li><strong>We are UK-based.</strong> We understand UK business culture, regulators (FCA, ICO, MHRA, NHS), and data protection requirements. GDPR compliance is baked into everything we ship.</li>
        </ul>

        <h2>What AI services do we specialise in?</h2>
        <ul>
          <li><strong><a href="/what-we-do/ai-strategy/">AI Strategy</a></strong> — Roadmaps, readiness assessments, opportunity identification</li>
          <li><strong><a href="/what-we-do/agentic-ai/">Agentic AI</a></strong> — Autonomous agents, multi-step workflows, tool-use systems</li>
          <li><strong><a href="/what-we-do/generative-ai/">Generative AI</a></strong> — LLMs, RAG architectures, prompt engineering</li>
          <li><strong><a href="/what-we-do/ai-automation/">AI Automation</a></strong> — Document extraction, workflow orchestration, integration layer</li>
          <li><strong><a href="/what-we-do/ai-governance/">AI Governance</a></strong> — Bias auditing, compliance frameworks, decision logging</li>
          <li><strong>Industry depth</strong> — Specialised delivery across <a href="/industries/healthcare/">healthcare</a>, <a href="/industries/finance/">finance</a>, <a href="/industries/legal/">legal</a>, <a href="/industries/manufacturing/">manufacturing</a>, retail, and education.</li>
        </ul>

        <h2>Who founded Agentic AI Associates?</h2>
        <p class="about-founder-lede"><strong>Sunny Patel founded Agentic AI Associates in 2026</strong>, after spending a decade building production data and AI systems for UK and international businesses. He built this website personally — it ranked on Google and generated an inbound enterprise lead within seven days of launch, which is the same speed and rigour he applies to client engagements. <a href="https://www.linkedin.com/in/sunnypatel" rel="noopener noreferrer">Connect on LinkedIn</a>.</p>
        <p>Sunny founded the firm because he saw too many businesses sold AI solutions they did not need, or told to wait when they should be acting. The approach is simple: understand the problem first, then apply the right technology.</p>

        <h3>Founder credentials and stack</h3>
        <ul>
          <li>Background in data engineering, applied AI systems, and operational workflow design</li>
          <li>Build stack: Python, LangChain, OpenAI, Anthropic Claude, Hugging Face, dbt, Astro, Next.js</li>
          <li>Workflow automation: n8n, Temporal, Make, and custom agentic pipelines</li>
          <li>Data: Postgres, BigQuery, dbt, with Cloudflare and Vercel for production deployment</li>
          <li>UK-based; fully GDPR-compliant; ICO-registered data practices; PI/PL cover placed before any Phase 2 engagement</li>
        </ul>

        <h2>What principles do we work by?</h2>
        <ul>
          <li><strong>Honesty first.</strong> If AI is not right for your problem, we will tell you. We would rather lose a project than waste your money.</li>
          <li><strong>Ship over plan.</strong> Working software over PowerPoint slides. Every engagement produces something real.</li>
          <li><strong>Measure everything.</strong> If we cannot measure the impact, we have not finished the job.</li>
          <li><strong>Practitioner-led.</strong> The person designing your system is the person building it. No handoffs to a delivery team.</li>
        </ul>

        <h2>Frequently asked questions about Agentic AI Associates</h2>
        <dl class="space-y-4 mt-4">
          {aboutFaqs.map((f) => (
            <div>
              <dt class="font-semibold" style="color:#EDEDEA;">{f.question}</dt>
              <dd class="mt-2 leading-relaxed" style="color:#8a8a92;">{f.answer}</dd>
            </div>
          ))}
        </dl>
      </div>

      <aside class="space-y-6">
        <div class="card">
          <h3 class="text-lg font-semibold mb-4">Quick Facts</h3>
          <dl class="space-y-3 text-sm">
            <div>
              <dt class="text-[var(--color-text-muted)]">Founded</dt>
              <dd class="font-medium">2026</dd>
            </div>
            <div>
              <dt class="text-[var(--color-text-muted)]">Location</dt>
              <dd class="font-medium">United Kingdom</dd>
            </div>
            <div>
              <dt class="text-[var(--color-text-muted)]">Speciality</dt>
              <dd class="font-medium">Agentic AI & Applied AI</dd>
            </div>
            <div>
              <dt class="text-[var(--color-text-muted)]">Focus</dt>
              <dd class="font-medium">Mid-market UK businesses</dd>
            </div>
          </dl>
        </div>

        <div class="card">
          <h3 class="text-lg font-semibold mb-2">See Our Results</h3>
          <p class="text-sm text-[var(--color-text-muted)] mb-5 leading-relaxed">Real outcomes from real projects — proof, not promises.</p>
          <a href="/about/results/" class="btn btn-outline text-sm w-full justify-center">View Results</a>
        </div>

        <div class="card bg-gradient-to-br from-[var(--color-accent)]/5 to-[var(--color-primary-light)]/5 border-[var(--color-accent)]/20">
          <h3 class="text-lg font-semibold mb-2">Ready to Talk?</h3>
          <p class="text-sm text-[var(--color-text-muted)] mb-5 leading-relaxed">30-minute fit call with the founder. No commitment, no jargon.</p>
          <a href="/contact/" class="btn btn-primary text-sm w-full justify-center">Book a Fit Call</a>
        </div>
      </aside>
    </div>
  </div>

  <CTABanner
    headline="Let's build something that actually works."
    text="Whether you're stepping into AI for the first time or scaling an existing programme, we'll tell you straight whether a Diagnostic is the right next move."
    buttonText="Book a Fit Call"
    buttonHref="/contact/"
  />
</BaseLayout>
