---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BreadcrumbNav from '@/components/BreadcrumbNav.astro';
import ContactForm from '@/components/ContactForm.astro';
import { siteConfig } from '@/data/site-config';

const sent = Astro.url.searchParams.get('sent') === 'true';
---

<BaseLayout
  title="Contact Us — Hire an AI Consultant | Agentic AI Associates"
  description="Get in touch with Agentic AI Associates. Book a free AI consultation or send us a message. UK-based AI consultancy, ready to help."
>
  <!-- Hero -->
  <section class="bg-[var(--color-hero-bg)] text-[var(--color-hero-text)] section">
    <div class="container">
      <BreadcrumbNav items={[{ label: 'Contact', href: '/contact/' }]} />
      <h1 class="text-white max-w-3xl">Get in Touch</h1>
      <p class="text-lg text-slate-300 mt-4 max-w-2xl leading-relaxed">Book a free consultation or send us a message. We typically respond within 24 hours.</p>
    </div>
  </section>

  <div class="container section-sm">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Contact form -->
      <div>
        <h2 class="mb-6">Send Us a Message</h2>

        {sent && (
          <div class="mb-6 p-4 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm">
            <strong>Message sent.</strong> We'll get back to you within 24 hours.
          </div>
        )}

        <ContactForm />
      </div>

      <!-- Right side -->
      <div class="space-y-8">
        <div>
          <h2 class="mb-6">Book a Free Consultation</h2>
          <p class="text-[var(--color-text-muted)] mb-4">Prefer to talk? Book a 30-minute discovery call. No sales pitch — just an honest conversation about your AI challenges.</p>
          <a href={siteConfig.contact.calendlyUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            Book a Call on Calendly
          </a>
        </div>

        <div class="card">
          <h3 class="text-lg font-semibold mb-4">What Happens Next?</h3>
          <ol class="space-y-4 text-sm">
            <li class="flex gap-3">
              <span class="w-6 h-6 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center text-xs font-bold text-[var(--color-accent)] flex-shrink-0">1</span>
              <div>
                <strong>We listen.</strong> Tell us about your business and what you're trying to achieve.
              </div>
            </li>
            <li class="flex gap-3">
              <span class="w-6 h-6 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center text-xs font-bold text-[var(--color-accent)] flex-shrink-0">2</span>
              <div>
                <strong>We assess.</strong> We'll give you an honest view of where AI can (and can't) help.
              </div>
            </li>
            <li class="flex gap-3">
              <span class="w-6 h-6 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center text-xs font-bold text-[var(--color-accent)] flex-shrink-0">3</span>
              <div>
                <strong>We propose.</strong> If there's a fit, we'll send a clear proposal with scope, timeline, and pricing.
              </div>
            </li>
          </ol>
        </div>

        <div class="card">
          <h3 class="text-lg font-semibold mb-3">Contact Details</h3>
          <dl class="space-y-3 text-sm">
            <div>
              <dt class="text-[var(--color-text-muted)]">Email</dt>
              <dd>
                <a href={`mailto:${siteConfig.contact.email}`} class="text-[var(--color-primary-light)] hover:text-[var(--color-accent)]">
                  {siteConfig.contact.email}
                </a>
              </dd>
            </div>
            <div>
              <dt class="text-[var(--color-text-muted)]">Location</dt>
              <dd class="font-medium">United Kingdom</dd>
            </div>
            <div>
              <dt class="text-[var(--color-text-muted)]">Response Time</dt>
              <dd class="font-medium">Within 24 hours</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
