---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — Agentic AI Associates"
  description="The page you're looking for doesn't exist."
  noIndex={true}
>
  <section class="section text-center">
    <div class="container max-w-xl">
      <p class="text-6xl font-bold text-gradient font-[family-name:var(--font-display)] mb-4">404</p>
      <h1 class="text-2xl mb-4">Page Not Found</h1>
      <p class="text-[var(--color-text-muted)] mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn btn-primary">Go Home</a>
        <a href="/contact/" class="btn btn-outline">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>
