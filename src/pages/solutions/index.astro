---
import HubLayout from '@/layouts/HubLayout.astro';
import { getSolutionsHub } from '@/lib/page-factory';
import { buildFAQSchema } from '@/lib/schema';

const data = getSolutionsHub();

const faqs = [
  { question: 'What AI solutions do you deliver?', answer: 'We deliver automation, data analysis, content creation, customer support, forecasting, compliance monitoring, lead generation, report generation, inventory management, and process improvement solutions — all powered by AI.' },
  { question: 'Can you combine multiple solutions in one project?', answer: 'Yes, and we often do. For example, a retail client might need demand forecasting combined with inventory management. We design integrated solutions rather than isolated tools.' },
  { question: 'How do you measure the success of an AI solution?', answer: 'Every project starts with clear KPIs. We measure impact through before-and-after comparisons — time saved, accuracy improved, costs reduced, or revenue generated. If we cannot measure it, we have not finished.' },
];

const schema = buildFAQSchema(faqs);
---

<HubLayout
  title={data.hub.title}
  description={data.hub.description}
  heroTitle="AI Solutions"
  heroSubtitle="Practical AI applications that solve real business problems. From automation to forecasting, delivered by experienced consultants."
  breadcrumbs={[{ label: 'Solutions', href: '/solutions/' }]}
  pages={data.pages.map((p) => ({ slug: p.slug, name: p.name, description: p.description, icon: p.icon }))}
  hubPath="/solutions/"
  faqs={faqs}
  schema={schema ? [schema] : []}
>
  <Fragment slot="intro">
    <div class="prose max-w-3xl">
      <p>AI can do a lot. But not everything needs AI. We help you identify which solutions will have the biggest impact on your business — and then we build them.</p>
      <p>Each solution below can be applied across multiple industries. Click through to see how it works, real use cases, and which industries benefit most.</p>
    </div>
  </Fragment>
</HubLayout>
