---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/data/site-config';

const insights = [
  {
    slug: 'agent-studio-build-vs-buy',
    title: 'Agent Studio: Build vs Buy for Regulated Enterprises',
    description: 'A 12-row scoring matrix across LangGraph, Bedrock Agents, Copilot Studio, Vertex AI, Writer, Glean, and custom builds — judged on the criteria that matter to FCA-regulated and £bn-AUM organisations.',
    date: '2026-04-30',
    readTime: '12 min',
  },
  {
    slug: 'agentic-sdlc-regulated-engineering',
    title: 'Agentic SDLC for Regulated Engineering Teams',
    description: 'How regulated engineering teams ship safely with agents — phased delivery framework, audit-trail design, SM&CR control mapping, and a reference architecture for FCA-supervised firms.',
    date: '2026-04-30',
    readTime: '15 min',
  },
  {
    slug: 'fca-ai-governance-playbook',
    title: 'FCA AI Governance Playbook: SM&CR, Consumer Duty, Model Risk',
    description: 'An operational playbook for AI deployment under the FCA AI Approach — Senior Manager mapping (SMF4/SMF24), Consumer Duty outcome rubric, and a downloadable AI Risk Register schema.',
    date: '2026-04-30',
    readTime: '14 min',
  },
  {
    slug: 'smcr-ai-accountability',
    title: 'SM&CR and AI: Who\'s Accountable When an Agent Goes Wrong?',
    description: 'A working answer to the question every Senior Manager at a UK regulated firm is now asking — six scenarios, six SMF assignments, and the evidence each holder must produce.',
    date: '2026-04-30',
    readTime: '9 min',
  },
  {
    slug: 'langgraph-vs-bedrock-vs-copilot-studio',
    title: 'LangGraph vs Bedrock Agents vs Copilot Studio: A Regulated Buyer\'s Comparison',
    description: 'A focused comparison of the three platforms most often shortlisted by FCA-regulated UK firms — audit fidelity, model portability, identity, cost predictability, and the lock-in nobody quotes.',
    date: '2026-04-30',
    readTime: '10 min',
  },
  {
    slug: 'ai-sdlc-audit-trail',
    title: 'AI SDLC Audit Trail: 12 Fields the FCA Will Ask About',
    description: 'A field-by-field reference for the audit-trail schema regulated firms need when agents touch the software delivery pipeline — what to capture, why, where to store it, and the failure modes that void the evidence.',
    date: '2026-04-30',
    readTime: '11 min',
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Insights',
  description: 'Original methodology, frameworks, and reference architectures from Agentic AI Associates.',
  url: `${siteConfig.url}/insights/`,
  hasPart: insights.map((i) => ({
    '@type': 'Article',
    headline: i.title,
    description: i.description,
    url: `${siteConfig.url}/insights/${i.slug}/`,
    datePublished: i.date,
    author: { '@type': 'Person', name: siteConfig.founder.name },
  })),
};
---

<BaseLayout
  title="Insights — Agentic AI Associates"
  description="Original methodology, frameworks, and reference architectures for organisations deploying agentic AI in regulated environments."
  schema={schema}
>
  <section class="mx-auto max-w-5xl px-6 py-20">
    <header class="mb-16">
      <p class="text-sm font-semibold uppercase tracking-wider text-cyan-400 mb-4">Insights</p>
      <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight text-white mb-6">Frameworks for the buyers nobody else writes for.</h1>
      <p class="text-xl text-slate-300 max-w-3xl">Architecture, governance, and operating-model thinking for regulated UK organisations deploying agentic AI. No vendor pitches. No analyst clichés.</p>
    </header>

    <ul class="space-y-12">
      {insights.map((i) => (
        <li class="border-l-2 border-cyan-500/30 pl-8 hover:border-cyan-400 transition-colors">
          <a href={`/insights/${i.slug}/`} class="block group">
            <p class="text-sm text-slate-400 mb-2"><time datetime={i.date}>{new Date(i.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</time> · {i.readTime} read</p>
            <h2 class="text-3xl font-bold text-white group-hover:text-cyan-300 transition-colors mb-3">{i.title}</h2>
            <p class="text-lg text-slate-300 max-w-3xl">{i.description}</p>
            <p class="mt-4 text-cyan-400 font-semibold">Read the framework →</p>
          </a>
        </li>
      ))}
    </ul>

    <div class="mt-24 p-8 rounded-xl bg-gradient-to-br from-cyan-950/40 to-slate-900 border border-cyan-500/20">
      <h2 class="text-2xl font-bold text-white mb-3">Want this thinking applied to your business?</h2>
      <p class="text-slate-300 mb-6">A Phase-Gate Diagnostic is two weeks, £6,500, and ends with a written architecture and operating-model assessment your board can act on.</p>
      <a href="/get-started/" class="inline-block px-6 py-3 rounded-lg bg-cyan-500 text-slate-950 font-semibold hover:bg-cyan-400 transition-colors">Book a Fit Call →</a>
    </div>
  </section>
</BaseLayout>
