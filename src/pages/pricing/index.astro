---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BreadcrumbNav from '@/components/BreadcrumbNav.astro';
import FAQ from '@/components/FAQ.astro';
import CTABanner from '@/components/CTABanner.astro';
import { buildFAQSchema } from '@/lib/schema';

const faqs = [
  { question: 'What is a typical AI consultant hourly rate?', answer: 'AI consultant hourly rates in the UK typically range from £100 to £250 per hour, depending on the complexity of the project and the seniority of the consultant. Our rates reflect the depth of expertise we bring and the measurable outcomes we deliver.' },
  { question: 'Do you offer fixed-price projects?', answer: 'Yes. For well-defined projects, we prefer fixed-price engagements. You know exactly what you\'re paying upfront, with no surprises. For ongoing advisory work, we offer retainer packages.' },
  { question: 'What does a free consultation include?', answer: 'A 30-minute call where we listen to your challenges, assess whether AI is the right solution, and give you an honest recommendation. No sales pitch. If there\'s a fit, we\'ll follow up with a detailed proposal.' },
  { question: 'How long does a typical AI project take?', answer: 'It depends on scope. A focused AI strategy can be delivered in 2-4 weeks. Implementation projects typically run 4-12 weeks. We always provide clear timelines in our proposals.' },
  { question: 'Do you work with small businesses?', answer: 'Absolutely. We\'ve designed our advisory packages specifically for small businesses and startups who want expert guidance without enterprise budgets.' },
];

const schema = buildFAQSchema(faqs);
---

<BaseLayout
  title="AI Consultant Pricing & Rates — Agentic AI Associates"
  description="Transparent AI consultancy pricing. From advisory sessions to full implementation projects. UK-based AI consultant rates and engagement models."
  schema={schema ? [schema] : []}
>
  <!-- Hero -->
  <section class="bg-[var(--color-hero-bg)] text-[var(--color-hero-text)] section">
    <div class="container">
      <BreadcrumbNav items={[{ label: 'Pricing', href: '/pricing/' }]} />
      <h1 class="text-white max-w-3xl">Pricing</h1>
      <p class="text-lg text-slate-300 mt-4 max-w-2xl leading-relaxed">Transparent pricing. No hidden fees. Every engagement starts with a free consultation.</p>
    </div>
  </section>

  <div class="container section-sm">
    <!-- Pricing tiers -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      <!-- Advisory -->
      <div class="card flex flex-col">
        <div class="mb-6">
          <h2 class="text-xl font-semibold">Advisory</h2>
          <p class="text-sm text-[var(--color-text-muted)] mt-1">Expert guidance, your pace</p>
        </div>
        <div class="mb-6">
          <span class="text-3xl font-bold text-gradient font-[family-name:var(--font-display)]">From £150</span>
          <span class="text-sm text-[var(--color-text-muted)]"> / hour</span>
        </div>
        <ul class="space-y-3 text-sm flex-1 mb-6">
          <li class="flex gap-2"><span class="text-[var(--color-success)]">&#10003;</span> 1:1 AI advisory sessions</li>
          <li class="flex gap-2"><span class="text-[var(--color-success)]">&#10003;</span> AI readiness assessment</li>
          <li class="flex gap-2"><span class="text-[var(--color-success)]">&#10003;</span> Technology recommendations</li>
          <li class="flex gap-2"><span class="text-[var(--color-success)]">&#10003;</span> Vendor evaluation support</li>
          <li class="flex gap-2"><span class="text-[var(--color-success)]">&#10003;</span> Email follow-up notes</li>
        </ul>
        <a href="/contact/" class="btn btn-outline w-full">Book Advisory</a>
      </div>

      <!-- Strategy -->
      <div class="card flex flex-col border-[var(--color-accent)] border-2 relative">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[var(--color-accent)] text-white text-xs font-bold px-3 py-1 rounded-full">Most Popular</div>
        <div class="mb-6">
          <h2 class="text-xl font-semibold">Strategy</h2>
          <p class="text-sm text-[var(--color-text-muted)] mt-1">Full AI roadmap, delivered</p>
        </div>
        <div class="mb-6">
          <span class="text-3xl font-bold text-gradient font-[family-name:var(--font-display)]">From £3,000</span>
          <span class="text-sm text-[var(--color-text-muted)]"> / project</span>
        </div>
        <ul class="space-y-3 text-sm flex-1 mb-6">
          <li class="flex gap-2"><span class="text-[var(--color-success)]">&#10003;</span> Discovery workshops</li>
          <li class="flex gap-2"><span class="text-[var(--color-success)]">&#10003;</span> AI opportunity mapping</li>
          <li class="flex gap-2"><span class="text-[var(--color-success)]">&#10003;</span> Technology architecture</li>
          <li class="flex gap-2"><span class="text-[var(--color-success)]">&#10003;</span> Implementation roadmap</li>
          <li class="flex gap-2"><span class="text-[var(--color-success)]">&#10003;</span> ROI projections</li>
          <li class="flex gap-2"><span class="text-[var(--color-success)]">&#10003;</span> 30-day follow-up support</li>
        </ul>
        <a href="/contact/" class="btn btn-primary w-full">Get a Strategy</a>
      </div>

      <!-- Implementation -->
      <div class="card flex flex-col">
        <div class="mb-6">
          <h2 class="text-xl font-semibold">Implementation</h2>
          <p class="text-sm text-[var(--color-text-muted)] mt-1">We build and deploy it</p>
        </div>
        <div class="mb-6">
          <span class="text-3xl font-bold text-gradient font-[family-name:var(--font-display)]">Custom</span>
          <span class="text-sm text-[var(--color-text-muted)]"> / scoped</span>
        </div>
        <ul class="space-y-3 text-sm flex-1 mb-6">
          <li class="flex gap-2"><span class="text-[var(--color-success)]">&#10003;</span> Full AI system build</li>
          <li class="flex gap-2"><span class="text-[var(--color-success)]">&#10003;</span> Integration with your stack</li>
          <li class="flex gap-2"><span class="text-[var(--color-success)]">&#10003;</span> Testing & deployment</li>
          <li class="flex gap-2"><span class="text-[var(--color-success)]">&#10003;</span> Team training included</li>
          <li class="flex gap-2"><span class="text-[var(--color-success)]">&#10003;</span> 90-day support period</li>
          <li class="flex gap-2"><span class="text-[var(--color-success)]">&#10003;</span> Performance monitoring</li>
        </ul>
        <a href="/contact/" class="btn btn-outline w-full">Discuss Your Project</a>
      </div>
    </div>

    <!-- Retainer note -->
    <div class="mt-12 max-w-3xl mx-auto text-center">
      <p class="text-[var(--color-text-muted)]">
        <strong class="text-[var(--color-text)]">Retainer packages</strong> also available for ongoing AI advisory and support. Starting from £1,500/month.
        <a href="/contact/" class="text-[var(--color-primary-light)] hover:text-[var(--color-accent)]">Contact us for details</a>.
      </p>
    </div>
  </div>

  <!-- FAQ -->
  <div class="container">
    <FAQ faqs={faqs} heading="Pricing FAQs" />
  </div>

  <!-- CTA -->
  <CTABanner
    headline="Every Engagement Starts with a Free Call"
    text="30 minutes, no obligation. Tell us what you're working on and we'll give you an honest assessment."
  />
</BaseLayout>
