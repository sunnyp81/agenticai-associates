---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BreadcrumbNav from '@/components/BreadcrumbNav.astro';
import FeatureGrid from '@/components/FeatureGrid.astro';
import FAQ from '@/components/FAQ.astro';
import CTABanner from '@/components/CTABanner.astro';
import RelatedLinks from '@/components/RelatedLinks.astro';
import HeroSignal from '@/components/HeroSignal.astro';
import { buildFAQSchema } from '@/lib/schema';
import { getBusinessSizePaths, getRelatedWhatWeDo } from '@/lib/page-factory';

export function getStaticPaths() {
  return getBusinessSizePaths();
}

const { page } = Astro.props;

const faqSchema = buildFAQSchema(page.faq);
const schemas = faqSchema ? [faqSchema] : [];
const relatedServices = getRelatedWhatWeDo(page.relatedServices);
---

<BaseLayout title={page.title} description={page.description} schema={schemas}>
  <section class="bg-[var(--color-hero-bg)] text-[var(--color-hero-text)] section relative overflow-hidden">
    <HeroSignal variant="orbit" seed={page.slug} />
    <div class="container relative">
      <BreadcrumbNav items={[
        { label: page.name, href: `/for/${page.slug}/` },
      ]} />
      <h1 class="text-white max-w-3xl">{page.name}</h1>
      <p class="text-lg text-slate-300 mt-4 max-w-2xl leading-relaxed">{page.intro}</p>
      <a href="/contact/" class="btn btn-primary mt-6">Get Started</a>
    </div>
  </section>

  <div class="container section-sm">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <div class="lg:col-span-2">
        <div class="prose">
          {page.sections.map((section: { heading: string; body: string }) => (
            <div>
              <h2>{section.heading}</h2>
              <Fragment set:html={section.body} />
            </div>
          ))}
        </div>

        {page.features.length > 0 && (
          <div class="mt-12">
            <h2 class="mb-6">What You Get</h2>
            <FeatureGrid features={page.features} columns={2} />
          </div>
        )}
      </div>

      <aside class="space-y-6">
        {relatedServices.length > 0 && (
          <RelatedLinks
            title="Recommended Services"
            links={relatedServices.map((svc) => ({
              label: svc.name,
              href: `/what-we-do/${svc.slug}/`,
            }))}
          />
        )}
      </aside>
    </div>
  </div>

  {page.faq.length > 0 && (
    <div class="container">
      <FAQ faqs={page.faq} />
    </div>
  )}

  <CTABanner
    headline={`AI Consultancy for ${page.name.replace('AI Consultant for ', '').replace('AI Consultancy for ', '')}`}
    text="Book a 30-minute fit call. We will assess the pressure points and tell you straight whether a Phase 1 Diagnostic is the right fit."
  />
</BaseLayout>
