---
import HubLayout from '@/layouts/HubLayout.astro';
import { getLearnHub } from '@/lib/page-factory';
import { buildFAQSchema } from '@/lib/schema';

const data = getLearnHub();

const faqs = [
  { question: 'Who are these guides for?', answer: 'Everyone. Whether you are considering hiring an AI consultant, thinking about becoming one, or just curious about the field — these guides are written in plain English with no prerequisites.' },
  { question: 'Are these guides free?', answer: 'Yes. All our learning content is free. We believe in sharing knowledge openly. If you need hands-on help, that is what our consultancy services are for.' },
  { question: 'How often is the content updated?', answer: 'We review and update all guides regularly. AI moves fast, so we make sure salary data, certifications, and industry trends reflect the current landscape.' },
];

const schema = buildFAQSchema(faqs);
---

<HubLayout
  title={data.hub.title}
  description={data.hub.description}
  heroTitle="Learn About AI Consulting"
  heroSubtitle="Practical guides on AI consulting — what it is, how to get started, and how to make the most of it. Written for real people, not academics."
  breadcrumbs={[{ label: 'Learn', href: '/learn/' }]}
  pages={data.pages.map((p) => ({ slug: p.slug, name: p.name, description: p.description }))}
  hubPath="/learn/"
  faqs={faqs}
  schema={schema ? [schema] : []}
>
  <Fragment slot="intro">
    <div class="prose max-w-3xl">
      <p>AI consulting is a fast-growing field. Whether you want to hire a consultant, become one, or simply understand the landscape, these guides have you covered.</p>
      <p>Every article is written in plain English by practising AI consultants. No fluff, no filler — just the information you need.</p>
    </div>
  </Fragment>
</HubLayout>
