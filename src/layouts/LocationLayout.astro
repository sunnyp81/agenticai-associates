---
import BaseLayout from './BaseLayout.astro';
import BreadcrumbNav from '@/components/BreadcrumbNav.astro';
import FAQ from '@/components/FAQ.astro';
import CTABanner from '@/components/CTABanner.astro';
import RelatedLinks from '@/components/RelatedLinks.astro';
import { buildLocalBusinessSchema, buildFAQSchema } from '@/lib/schema';
import { siteConfig } from '@/data/site-config';

interface Props {
  page: {
    slug: string;
    name: string;
    title: string;
    description: string;
    intro: string;
    areaServed: string;
    region?: string;
    sections: { heading: string; body: string }[];
    faq: { question: string; answer: string }[];
    relatedLocations: string[];
    relatedServices: string[];
  };
}

const { page } = Astro.props;

const localSchema = buildLocalBusinessSchema({
  name: page.name,
  description: page.description,
  url: `${siteConfig.url}/locations/${page.slug}/`,
  areaServed: page.areaServed,
  region: page.region,
});

const faqSchema = buildFAQSchema(page.faq);
const schemas = [localSchema, ...(faqSchema ? [faqSchema] : [])];
---

<BaseLayout title={page.title} description={page.description} schema={schemas}>
  <!-- Hero -->
  <section class="bg-[var(--color-hero-bg)] text-[var(--color-hero-text)] section">
    <div class="container">
      <BreadcrumbNav items={[
        { label: 'Locations', href: '/locations/' },
        { label: page.name, href: `/locations/${page.slug}/` },
      ]} />
      <h1 class="text-white max-w-3xl">{page.name}</h1>
      <p class="text-lg text-slate-300 mt-4 max-w-2xl leading-relaxed">{page.intro}</p>
      <a href="/contact/" class="btn btn-primary mt-6">Get Local AI Advice</a>
    </div>
  </section>

  <div class="container section-sm">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Main content -->
      <div class="lg:col-span-2 prose">
        {page.sections.map((section) => (
          <div>
            <h2>{section.heading}</h2>
            <Fragment set:html={section.body} />
          </div>
        ))}
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <RelatedLinks
          title="Our Services"
          links={page.relatedServices.map((slug) => ({
            label: slug.replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase()),
            href: `/services/${slug}/`,
          }))}
        />

        {page.relatedLocations.length > 0 && (
          <RelatedLinks
            title="Nearby Locations"
            links={page.relatedLocations.map((slug) => ({
              label: `AI Consultancy ${slug.replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase())}`,
              href: `/locations/${slug}/`,
            }))}
          />
        )}
      </aside>
    </div>
  </div>

  <!-- FAQ -->
  {page.faq.length > 0 && (
    <div class="container">
      <FAQ faqs={page.faq} />
    </div>
  )}

  <!-- CTA -->
  <CTABanner
    headline={`AI Consultancy in ${page.areaServed}`}
    text={`Looking for an AI consultant in ${page.areaServed}? Book a free consultation with our team.`}
  />
</BaseLayout>
