---
import BaseLayout from './BaseLayout.astro';
import BreadcrumbNav from '@/components/BreadcrumbNav.astro';
import FAQ from '@/components/FAQ.astro';
import CTABanner from '@/components/CTABanner.astro';
import RelatedLinks from '@/components/RelatedLinks.astro';
import HeroSignal from '@/components/HeroSignal.astro';
import { buildDefinedTermSchema, buildSpeakableSchema } from '@/lib/schema';
import { siteConfig } from '@/data/site-config';
import { getRelatedWhatWeDo } from '@/lib/page-factory';

interface Props {
  page: {
    slug: string;
    name: string;
    title: string;
    description: string;
    intro: string;
    painPoints: { title: string; description: string }[];
    solutionSections: { solution: string; heading: string; body: string; linkSlug: string }[];
    faq: { question: string; answer: string }[];
    relatedServices: string[];
    relatedIndustries: string[];
    definedTerm?: { term: string; definition: string; sameAs?: string[] };
  };
}

const { page } = Astro.props;
const pageUrl = `${siteConfig.url}/industries/${page.slug}/`;

// FAQPage schema is emitted by the FAQ.astro component — do not duplicate here.
const definedTermSchema = page.definedTerm
  ? buildDefinedTermSchema({
      term: page.definedTerm.term,
      definition: page.definedTerm.definition,
      url: `${pageUrl}#defined-term`,
      sameAs: page.definedTerm.sameAs,
    })
  : null;
const speakableSchema = buildSpeakableSchema({
  url: pageUrl,
  cssSelectors: ['.page-intro', '.page-h1'],
});

const schemas = [
  speakableSchema,
  ...(definedTermSchema ? [definedTermSchema] : []),
];

const relatedServices = getRelatedWhatWeDo(page.relatedServices);
---

<BaseLayout title={page.title} description={page.description} schema={schemas}>
  <!-- Hero -->
  <section class="bg-[var(--color-hero-bg)] text-[var(--color-hero-text)] section relative overflow-hidden">
    <HeroSignal variant="orbit" seed={page.slug} />
    <div class="container relative">
      <BreadcrumbNav items={[
        { label: 'Industries', href: '/industries/' },
        { label: page.name, href: `/industries/${page.slug}/` },
      ]} />
      <h1 class="page-h1 text-white max-w-3xl">{page.name}</h1>
      <div class="page-intro text-lg text-slate-300 mt-4 max-w-2xl leading-relaxed prose prose-invert prose-p:my-0"><Fragment set:html={page.intro} /></div>
      {page.definedTerm && (
        <div id="defined-term" class="sr-only" itemscope itemtype="https://schema.org/DefinedTerm">
          <span itemprop="name">{page.definedTerm.term}</span>:
          <span itemprop="description">{page.definedTerm.definition}</span>
        </div>
      )}
      <a href="/contact/" class="btn btn-primary mt-6">Get Industry-Specific Advice</a>
    </div>
  </section>

  <div class="container section-sm">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Main content -->
      <div class="lg:col-span-2 order-1">
        <!-- Pain points -->
        {page.painPoints.length > 0 && (
          <section class="mb-12">
            <h2 class="mb-6">Challenges We Solve</h2>
            <div class="space-y-4">
              {page.painPoints.map((point) => (
                <div class="card">
                  <h3 class="text-lg font-semibold mb-2">{point.title}</h3>
                  <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{point.description}</p>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- Solution sections (captures "ai consultant for [solution] in [industry]") -->
        {page.solutionSections.length > 0 && (
          <section class="prose">
            <h2>How AI Transforms {page.name.replace('AI for ', '')}</h2>
            {page.solutionSections.map((section) => (
              <div>
                <h3>{section.heading}</h3>
                <Fragment set:html={section.body} />
                <p>
                  <a href={section.linkSlug}>Learn more about our {section.heading.toLowerCase()} services</a>.
                </p>
              </div>
            ))}
          </section>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6 order-2 lg:order-none">
        {relatedServices.length > 0 && (
          <RelatedLinks
            title="Our Services"
            links={relatedServices.map((svc) => ({
              label: svc.name,
              href: `/what-we-do/${svc.slug}/`,
            }))}
          />
        )}

        {page.relatedIndustries.length > 0 && (
          <RelatedLinks
            title="Related Industries"
            links={page.relatedIndustries.map((slug) => ({
              label: slug.replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase()),
              href: `/industries/${slug}/`,
            }))}
          />
        )}
      </aside>
    </div>
  </div>

  <!-- FAQ -->
  {page.faq.length > 0 && (
    <div class="container">
      <FAQ faqs={page.faq} />
    </div>
  )}

  <!-- CTA -->
  <CTABanner
    headline={`AI Solutions for ${page.name.replace('AI for ', '')}`}
    text="We understand your industry. Let's discuss how AI can solve your specific challenges."
  />
</BaseLayout>
