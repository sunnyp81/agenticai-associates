---
import BaseLayout from './BaseLayout.astro';
import BreadcrumbNav from '@/components/BreadcrumbNav.astro';
import FAQ from '@/components/FAQ.astro';
import CTABanner from '@/components/CTABanner.astro';
import RelatedLinks from '@/components/RelatedLinks.astro';
import { buildFAQSchema } from '@/lib/schema';
import { siteConfig } from '@/data/site-config';
import { getRelatedServices, getRelatedIndustries } from '@/lib/page-factory';

interface Props {
  page: {
    slug: string;
    name: string;
    title: string;
    description: string;
    intro: string;
    sections: { heading: string; body: string }[];
    useCases: { title: string; description: string }[];
    industrySections: { industry: string; heading: string; body: string; linkSlug: string }[];
    faq: { question: string; answer: string }[];
    relatedServices: string[];
    relatedIndustries: string[];
  };
}

const { page } = Astro.props;

const faqSchema = buildFAQSchema(page.faq);
const schemas = faqSchema ? [faqSchema] : [];

const relatedServices = getRelatedServices(page.relatedServices);
const relatedIndustries = getRelatedIndustries(page.relatedIndustries);
---

<BaseLayout title={page.title} description={page.description} schema={schemas}>
  <!-- Hero -->
  <section class="bg-[var(--color-hero-bg)] text-[var(--color-hero-text)] section">
    <div class="container">
      <BreadcrumbNav items={[
        { label: 'Solutions', href: '/solutions/' },
        { label: page.name, href: `/solutions/${page.slug}/` },
      ]} />
      <h1 class="text-white max-w-3xl">{page.name}</h1>
      <div class="text-lg text-slate-300 mt-4 max-w-2xl leading-relaxed prose prose-invert prose-p:my-0"><Fragment set:html={page.intro} /></div>
      <a href="/contact/" class="btn btn-primary mt-6">Explore This Solution</a>
    </div>
  </section>

  <div class="container section-sm">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Main content -->
      <div class="lg:col-span-2 order-1">
        <!-- Prose sections -->
        <div class="prose">
          {page.sections.map((section) => (
            <div>
              <h2>{section.heading}</h2>
              <Fragment set:html={section.body} />
            </div>
          ))}
        </div>

        <!-- Use cases -->
        {page.useCases.length > 0 && (
          <section class="mt-12">
            <h2 class="mb-6">Use Cases</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {page.useCases.map((uc) => (
                <div class="card">
                  <h3 class="text-base font-semibold mb-2">{uc.title}</h3>
                  <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{uc.description}</p>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- Industry cross-links -->
        {page.industrySections.length > 0 && (
          <section class="prose mt-12">
            <h2>Industries We Apply {page.name} To</h2>
            {page.industrySections.map((section) => (
              <div>
                <h3>{section.heading}</h3>
                <Fragment set:html={section.body} />
                <p>
                  <a href={section.linkSlug}>See our {section.industry} solutions</a>.
                </p>
              </div>
            ))}
          </section>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6 order-2 lg:order-none">
        {relatedServices.length > 0 && (
          <RelatedLinks
            title="Related Services"
            links={relatedServices.map((svc) => ({
              label: svc.name,
              href: `/services/${svc.slug}/`,
            }))}
          />
        )}

        {relatedIndustries.length > 0 && (
          <RelatedLinks
            title="Industries"
            links={relatedIndustries.map((ind) => ({
              label: ind.name,
              href: `/industries/${ind.slug}/`,
            }))}
          />
        )}
      </aside>
    </div>
  </div>

  <!-- FAQ -->
  {page.faq.length > 0 && (
    <div class="container">
      <FAQ faqs={page.faq} />
    </div>
  )}

  <!-- CTA -->
  <CTABanner
    headline={`Implement ${page.name} in Your Business`}
    text="Talk to our team about how this solution can transform your operations."
  />
</BaseLayout>
