---
// Animated hero decoration for landing pages.
// 4 variants: network (neural swarm), orbit (gravitational system),
// flow (sequential pipeline), pulse (radial emanation).
// Pure SVG + SMIL + CSS, no JS. Hidden below md. Respects prefers-reduced-motion.
interface Props {
  variant?: 'network' | 'orbit' | 'flow' | 'pulse';
  seed?: string;
}

const { variant = 'network', seed = '' } = Astro.props;

// Deterministic per-page drift so sibling pages don't animate identically.
const hashSeed = seed
  ? seed.split('').reduce((a, c) => ((a << 5) - a + c.charCodeAt(0)) | 0, 0)
  : 0;
const drift = ((Math.abs(hashSeed) % 60) / 10).toFixed(2); // 0.00–5.90s
const driftNum = Number(drift);
---

<div class="hero-signal" aria-hidden="true" data-variant={variant}>
  <svg viewBox="0 0 420 280" xmlns="http://www.w3.org/2000/svg" class="hs-svg">
    <defs>
      <radialGradient id="hs-core-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%"  stop-color="#00E5FF" stop-opacity="0.75" />
        <stop offset="45%" stop-color="#00E5FF" stop-opacity="0.25" />
        <stop offset="100%" stop-color="#00E5FF" stop-opacity="0" />
      </radialGradient>
      <filter id="hs-blur" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="1.4" />
      </filter>
    </defs>

    {variant === 'network' && (
      <>
        {/* Faint core glow */}
        <circle class="hs-aura" cx="210" cy="140" r="120" fill="url(#hs-core-glow)" />

        {/* Static 8-edge topology rendered as rest-state rules;
            the rAF script paints the traversing packet + trail over the top. */}
        <g class="hs-agent-graph" data-offset={drift}>
          {/* Rest-state edges (dim rules) */}
          <line class="hs-edge-rest" x1="50"  y1="105" x2="150" y2="80"  data-i="0"/>
          <line class="hs-edge-rest" x1="50"  y1="105" x2="150" y2="200" data-i="1"/>
          <line class="hs-edge-rest" x1="150" y1="80"  x2="230" y2="140" data-i="2"/>
          <line class="hs-edge-rest" x1="150" y1="200" x2="230" y2="140" data-i="3"/>
          <line class="hs-edge-rest" x1="230" y1="140" x2="310" y2="110" data-i="4"/>
          <line class="hs-edge-rest" x1="310" y1="110" x2="310" y2="210" data-i="5"/>
          <line class="hs-edge-rest" x1="310" y1="110" x2="390" y2="150" data-i="6"/>
          <line class="hs-edge-rest" x1="310" y1="210" x2="390" y2="150" data-i="7"/>

          {/* Live trail segments (one per edge, painted from A to phase-point) */}
          <line class="hs-trail" data-i="0" x1="50"  y1="105" x2="50"  y2="105"/>
          <line class="hs-trail" data-i="1" x1="50"  y1="105" x2="50"  y2="105"/>
          <line class="hs-trail" data-i="2" x1="150" y1="80"  x2="150" y2="80" />
          <line class="hs-trail" data-i="3" x1="150" y1="200" x2="150" y2="200"/>
          <line class="hs-trail" data-i="4" x1="230" y1="140" x2="230" y2="140"/>
          <line class="hs-trail" data-i="5" x1="310" y1="110" x2="310" y2="110"/>
          <line class="hs-trail" data-i="6" x1="310" y1="110" x2="310" y2="110"/>
          <line class="hs-trail" data-i="7" x1="310" y1="210" x2="310" y2="210"/>

          {/* Packets — 2 circles each (glow + core), hidden until active */}
          <g class="hs-pkt-g" data-i="0"><circle class="hs-pkt-glow" r="3.5"/><circle class="hs-pkt-core" r="2"/></g>
          <g class="hs-pkt-g" data-i="1"><circle class="hs-pkt-glow" r="3.5"/><circle class="hs-pkt-core" r="2"/></g>
          <g class="hs-pkt-g" data-i="2"><circle class="hs-pkt-glow" r="3.5"/><circle class="hs-pkt-core" r="2"/></g>
          <g class="hs-pkt-g" data-i="3"><circle class="hs-pkt-glow" r="3.5"/><circle class="hs-pkt-core" r="2"/></g>
          <g class="hs-pkt-g" data-i="4"><circle class="hs-pkt-glow" r="3.5"/><circle class="hs-pkt-core" r="2"/></g>
          <g class="hs-pkt-g" data-i="5"><circle class="hs-pkt-glow" r="3.5"/><circle class="hs-pkt-core" r="2"/></g>
          <g class="hs-pkt-g" data-i="6"><circle class="hs-pkt-glow" r="3.5"/><circle class="hs-pkt-core" r="2"/></g>
          <g class="hs-pkt-g" data-i="7"><circle class="hs-pkt-glow" r="3.5"/><circle class="hs-pkt-core" r="2"/></g>

          {/* Nodes — INPUT / AGENT / TOOL / AGENT / AGENT / HUMAN / OUTPUT */}
          <g class="hs-n"><rect x="32"  y="92"  width="36" height="26" rx="4" data-role="input"/></g>
          <g class="hs-n hs-n-agent"><rect x="130" y="66"  width="40" height="28" rx="4" data-role="agent"/></g>
          <g class="hs-n"><rect x="130" y="186" width="40" height="28" rx="4" data-role="tool"/></g>
          <g class="hs-n hs-n-agent hs-n-core"><rect x="208" y="124" width="44" height="32" rx="5" data-role="agent"/></g>
          <g class="hs-n hs-n-agent"><rect x="290" y="96"  width="40" height="28" rx="4" data-role="agent"/></g>
          <g class="hs-n"><rect x="290" y="196" width="40" height="28" rx="4" data-role="human"/></g>
          <g class="hs-n"><rect x="370" y="134" width="36" height="32" rx="4" data-role="output"/></g>
        </g>
      </>
    )}

    {variant === 'orbit' && (
      <>
        {/* Deep core glow */}
        <circle class="hs-aura" cx="210" cy="140" r="100" fill="url(#hs-core-glow)"/>

        {/* Faint constellation backdrop */}
        <circle cx="50"  cy="40"  r="1"   fill="#00E5FF" opacity="0.4" />
        <circle cx="370" cy="55"  r="1"   fill="#00E5FF" opacity="0.35"/>
        <circle cx="40"  cy="225" r="1"   fill="#00E5FF" opacity="0.4" />
        <circle cx="380" cy="235" r="1"   fill="#00E5FF" opacity="0.35"/>
        <circle cx="90"  cy="95"  r="0.8" fill="#00E5FF" opacity="0.3" />
        <circle cx="335" cy="185" r="0.8" fill="#00E5FF" opacity="0.3" />

        {/* Two dashed orbit rings with animated dash offset (flowing circles) */}
        <circle class="hs-ring hs-ring-outer" cx="210" cy="140" r="95" fill="none"/>
        <circle class="hs-ring hs-ring-inner" cx="210" cy="140" r="55" fill="none"/>

        {/* Radial pulse — emanates from centre every 6s */}
        <circle class="hs-pulse" cx="210" cy="140" r="0" fill="none" stroke="#00E5FF" stroke-width="1.25">
          <animate attributeName="r"       values="12;120"        dur="6s" repeatCount="indefinite" begin={`-${drift}s`}/>
          <animate attributeName="opacity" values="0.9;0.9;0"     keyTimes="0;0.1;1" dur="6s" repeatCount="indefinite" begin={`-${drift}s`}/>
          <animate attributeName="stroke-width" values="1.5;0.5"  dur="6s" repeatCount="indefinite" begin={`-${drift}s`}/>
        </circle>

        {/* Outer orbital system — 4 satellites revolving counterclockwise */}
        <g class="hs-orbit-outer-group">
          <animateTransform attributeName="transform" type="rotate" from="0 210 140" to="-360 210 140"
            dur="30s" repeatCount="indefinite"/>
          <g class="hs-sat"><rect x="295" y="130" width="20" height="20" rx="3"/></g>
          <g class="hs-sat"><rect x="200" y="225" width="20" height="20" rx="3"/></g>
          <g class="hs-sat"><rect x="105" y="130" width="20" height="20" rx="3"/></g>
          <g class="hs-sat"><rect x="200" y="35"  width="20" height="20" rx="3"/></g>
        </g>

        {/* Inner orbital system — 3 satellites revolving clockwise, faster */}
        <g class="hs-orbit-inner-group">
          <animateTransform attributeName="transform" type="rotate" from="0 210 140" to="360 210 140"
            dur="18s" repeatCount="indefinite"/>
          <g class="hs-sat hs-sat-small"><rect x="258" y="133" width="14" height="14" rx="2.5"/></g>
          <g class="hs-sat hs-sat-small"><rect x="175" y="180" width="14" height="14" rx="2.5"/></g>
          <g class="hs-sat hs-sat-small"><rect x="175" y="86"  width="14" height="14" rx="2.5"/></g>
        </g>

        {/* Central node — brighter, wider glow, strong pulse */}
        <g class="hs-node-core">
          <rect class="hs-node-rect hs-node-core-rect" x="198" y="128" width="24" height="24" rx="4"/>
        </g>

        {/* Particles streaming along outer orbit — continuous flow in both directions */}
        <path id="hs-orbit-cw"  d="M 305,140 A 95,95 0 1 0 305.01,140 Z" fill="none" stroke="none"/>
        <path id="hs-orbit-ccw" d="M 305,140 A 95,95 0 1 1 304.99,140 Z" fill="none" stroke="none"/>
        <circle class="hs-pkt hs-pkt-bright" r="2.2" fill="#00E5FF">
          <animateMotion dur="10s" repeatCount="indefinite" begin={`-${drift}s`} rotate="auto">
            <mpath href="#hs-orbit-cw"/>
          </animateMotion>
        </circle>
        <circle class="hs-pkt hs-pkt-bright" r="2.2" fill="#00E5FF">
          <animateMotion dur="10s" repeatCount="indefinite" begin={`-${driftNum + 5}s`} rotate="auto">
            <mpath href="#hs-orbit-cw"/>
          </animateMotion>
        </circle>
        <circle class="hs-pkt" r="1.6" fill="#00E5FF">
          <animateMotion dur="14s" repeatCount="indefinite" begin={`-${driftNum + 2}s`} rotate="auto">
            <mpath href="#hs-orbit-ccw"/>
          </animateMotion>
        </circle>
      </>
    )}

    {variant === 'flow' && (
      <>
        <circle class="hs-aura" cx="210" cy="140" r="100" fill="url(#hs-core-glow)"/>
        <line class="hs-edge fe0" x1="50"  y1="140" x2="150" y2="90"  />
        <line class="hs-edge fe1" x1="150" y1="90"  x2="250" y2="140" />
        <line class="hs-edge fe2" x1="250" y1="140" x2="350" y2="90"  />
        <line class="hs-edge fe3" x1="50"  y1="140" x2="150" y2="190" />
        <line class="hs-edge fe4" x1="150" y1="190" x2="250" y2="140" />
        <line class="hs-edge fe5" x1="250" y1="140" x2="350" y2="190" />

        <g class="hs-node"><rect class="hs-node-rect" x="38"  y="128" width="24" height="24" rx="4"/></g>
        <g class="hs-node"><rect class="hs-node-rect" x="138" y="78"  width="24" height="24" rx="4"/></g>
        <g class="hs-node hs-node-core"><rect class="hs-node-rect" x="238" y="128" width="24" height="24" rx="4"/></g>
        <g class="hs-node"><rect class="hs-node-rect" x="338" y="78"  width="24" height="24" rx="4"/></g>
        <g class="hs-node"><rect class="hs-node-rect" x="138" y="178" width="24" height="24" rx="4"/></g>
        <g class="hs-node"><rect class="hs-node-rect" x="338" y="178" width="24" height="24" rx="4"/></g>

        <circle class="hs-pkt hs-pkt-bright" r="2" fill="#00E5FF">
          <animateMotion dur="6s" repeatCount="indefinite" begin={`-${drift}s`}
            path="M50,140 L150,90 L250,140 L350,90" calcMode="linear"/>
        </circle>
        <circle class="hs-pkt hs-pkt-bright" r="2" fill="#00E5FF">
          <animateMotion dur="6s" repeatCount="indefinite" begin={`-${driftNum + 3}s`}
            path="M50,140 L150,190 L250,140 L350,190" calcMode="linear"/>
        </circle>
        <circle class="hs-pkt" r="1.6" fill="#00E5FF">
          <animateMotion dur="8s" repeatCount="indefinite" begin={`-${driftNum + 1.5}s`}
            path="M50,140 L150,90 L250,140 L350,190" calcMode="linear"/>
        </circle>
      </>
    )}

    {variant === 'pulse' && (
      <>
        <circle class="hs-aura" cx="210" cy="140" r="120" fill="url(#hs-core-glow)"/>

        {/* Three concentric pulse rings emanating outward, staggered */}
        <circle class="hs-pulse" cx="210" cy="140" r="0" fill="none" stroke="#00E5FF" stroke-width="1.25">
          <animate attributeName="r"       values="15;140"    dur="5s" repeatCount="indefinite" begin={`-${drift}s`}/>
          <animate attributeName="opacity" values="0.8;0"     dur="5s" repeatCount="indefinite" begin={`-${drift}s`}/>
          <animate attributeName="stroke-width" values="2;0.3" dur="5s" repeatCount="indefinite" begin={`-${drift}s`}/>
        </circle>
        <circle class="hs-pulse" cx="210" cy="140" r="0" fill="none" stroke="#00E5FF" stroke-width="1.25">
          <animate attributeName="r"       values="15;140"    dur="5s" repeatCount="indefinite" begin={`-${driftNum + 1.66}s`}/>
          <animate attributeName="opacity" values="0.8;0"     dur="5s" repeatCount="indefinite" begin={`-${driftNum + 1.66}s`}/>
          <animate attributeName="stroke-width" values="2;0.3" dur="5s" repeatCount="indefinite" begin={`-${driftNum + 1.66}s`}/>
        </circle>
        <circle class="hs-pulse" cx="210" cy="140" r="0" fill="none" stroke="#00E5FF" stroke-width="1.25">
          <animate attributeName="r"       values="15;140"    dur="5s" repeatCount="indefinite" begin={`-${driftNum + 3.33}s`}/>
          <animate attributeName="opacity" values="0.8;0"     dur="5s" repeatCount="indefinite" begin={`-${driftNum + 3.33}s`}/>
          <animate attributeName="stroke-width" values="2;0.3" dur="5s" repeatCount="indefinite" begin={`-${driftNum + 3.33}s`}/>
        </circle>

        {/* Connected nodes on spokes */}
        <line class="hs-edge pe0" x1="210" y1="140" x2="210" y2="60"  />
        <line class="hs-edge pe1" x1="210" y1="140" x2="130" y2="100" />
        <line class="hs-edge pe2" x1="210" y1="140" x2="130" y2="180" />
        <line class="hs-edge pe3" x1="210" y1="140" x2="210" y2="220" />
        <line class="hs-edge pe4" x1="210" y1="140" x2="290" y2="180" />
        <line class="hs-edge pe5" x1="210" y1="140" x2="290" y2="100" />

        <g class="hs-node-core"><rect class="hs-node-rect hs-node-core-rect" x="198" y="128" width="24" height="24" rx="4"/></g>
        <g class="hs-node"><rect class="hs-node-rect" x="200" y="50"  width="20" height="20" rx="3"/></g>
        <g class="hs-node"><rect class="hs-node-rect" x="120" y="90"  width="20" height="20" rx="3"/></g>
        <g class="hs-node"><rect class="hs-node-rect" x="120" y="170" width="20" height="20" rx="3"/></g>
        <g class="hs-node"><rect class="hs-node-rect" x="200" y="210" width="20" height="20" rx="3"/></g>
        <g class="hs-node"><rect class="hs-node-rect" x="280" y="170" width="20" height="20" rx="3"/></g>
        <g class="hs-node"><rect class="hs-node-rect" x="280" y="90"  width="20" height="20" rx="3"/></g>
      </>
    )}
  </svg>
</div>

<style>
  .hero-signal {
    position: absolute;
    top: 0;
    right: 0;
    width: 460px;
    height: 300px;
    pointer-events: none;
    overflow: hidden;
    display: none;
    opacity: 0.55;
    z-index: 0;
    mask-image: linear-gradient(to left, black 55%, transparent 100%);
    -webkit-mask-image: linear-gradient(to left, black 55%, transparent 100%);
  }
  @media (min-width: 768px)  { .hero-signal { display: block; } }
  @media (min-width: 1280px) { .hero-signal { width: 560px; height: 340px; } }

  .hs-svg { width: 100%; height: 100%; display: block; overflow: visible; }

  /* ── Ambient core glow ─────────────────────────────────────── */
  .hs-aura {
    animation: hs-breathe 7s ease-in-out infinite;
    transform-origin: center;
  }
  @keyframes hs-breathe {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50%      { opacity: 0.95; transform: scale(1.08); }
  }

  /* ── Node rects — shared base ──────────────────────────────── */
  .hs-node-rect {
    fill: #050507;
    stroke: rgba(0,229,255, 0.75);
    stroke-width: 1;
  }
  .hs-node-core-rect {
    stroke: #00E5FF;
    stroke-width: 1.4;
    filter: drop-shadow(0 0 6px rgba(0,229,255, 0.55));
    animation: hs-core-pulse 3.5s ease-in-out infinite;
  }
  @keyframes hs-core-pulse {
    0%, 100% { filter: drop-shadow(0 0 4px rgba(0,229,255, 0.4)); }
    50%      { filter: drop-shadow(0 0 14px rgba(0,229,255, 0.8)); }
  }

  /* Accent dots on the network swarm */
  .hs-dot { fill: #00E5FF; opacity: 0.7; }

  /* ── Agent graph (network variant) — rAF-driven packet flow ─ */
  .hs-edge-rest {
    stroke: rgba(0, 229, 255, 0.18);
    stroke-width: 1;
    fill: none;
  }
  .hs-trail {
    stroke: #00E5FF;
    stroke-width: 1.6;
    stroke-linecap: round;
    fill: none;
    opacity: 0;
    /* drop-shadow removed: re-rasterized every frame as x2/y2 changed → mobile jitter.
       Trail brightness now relies on stroke colour + linecap alone. */
  }
  .hs-pkt-g { opacity: 0; }
  .hs-pkt-glow {
    fill: #00E5FF;
    opacity: 0.22;
    /* blur(2px) removed: filter re-raster on every transform tanked framerate.
       Glow now achieved via the larger r=3.5 halo circle + low opacity. */
  }
  .hs-pkt-core {
    fill: #00E5FF;
    /* drop-shadow removed for the same reason. */
  }
  .hs-n rect {
    fill: #050507;
    stroke: rgba(0, 229, 255, 0.45);
    stroke-width: 1;
  }
  .hs-n-agent rect {
    stroke: #00E5FF;
    stroke-width: 1.4;
  }
  .hs-n-core rect {
    filter: drop-shadow(0 0 8px rgba(0, 229, 255, 0.55));
    animation: hs-core-pulse 3.5s ease-in-out infinite;
  }

  /* ── Legacy network swarm (unused by network variant now, kept for future) ── */
  .hs-float { animation: hs-float-a 6s ease-in-out infinite; transform-origin: center; }
  .hs-float.nf0 { animation-duration: 5.4s; animation-delay:  -0.4s; }
  .hs-float.nf1 { animation-duration: 6.8s; animation-delay:  -1.2s; }
  .hs-float.nf2 { animation-duration: 5.1s; animation-delay:  -2.6s; }
  .hs-float.nf3 { animation-duration: 6.2s; animation-delay:  -3.1s; }
  .hs-float.nf4 { animation-duration: 5.9s; animation-delay:  -0.7s; }
  .hs-float.nf5 { animation-duration: 4.7s; animation-delay:  -1.9s; }
  .hs-float.nf6 { animation-duration: 5.5s; animation-delay:  -3.8s; }
  .hs-float.nf7 { animation-duration: 4.3s; animation-delay:  -2.1s; }
  .hs-float.nf8 { animation-duration: 5.2s; animation-delay:  -4.2s; }
  @keyframes hs-float-a {
    0%, 100% { transform: translate(0, 0); }
    25%      { transform: translate(2px, -3px); }
    50%      { transform: translate(-1px, 2px); }
    75%      { transform: translate(3px, 1px); }
  }

  .hs-edge {
    fill: none;
    stroke-width: 1;
    stroke: rgba(0,229,255, 0.2);
    stroke-dasharray: 4 5;
    animation: hs-edge-flicker 5s ease-in-out infinite;
  }
  .hs-edge.ne0 { animation-delay: -0.5s; }
  .hs-edge.ne1 { animation-delay: -1.8s; }
  .hs-edge.ne2 { animation-delay: -3.2s; }
  .hs-edge.ne3 { animation-delay: -0.9s; }
  .hs-edge.ne4 { animation-delay: -2.4s; }
  .hs-edge.ne5 { animation-delay: -4.1s; }
  .hs-edge.ne6 { animation-delay: -1.3s; }
  .hs-edge.ne7 { animation-delay: -3.7s; }
  @keyframes hs-edge-flicker {
    0%, 40%, 100% {
      stroke: rgba(0,229,255, 0.18);
      stroke-width: 1;
      stroke-dasharray: 4 5;
    }
    45%, 55% {
      stroke: rgba(0,229,255, 0.9);
      stroke-width: 1.5;
      stroke-dasharray: 0;
    }
  }

  /* Neural firing ring (network only) */
  .hs-fire {
    opacity: 0;
    animation: hs-fire-burst 7s ease-out infinite;
    transform-origin: 180px 140px;
  }
  @keyframes hs-fire-burst {
    0%       { opacity: 0.9; r: 12; stroke-width: 1.5; }
    40%      { opacity: 0;   r: 90; stroke-width: 0.3; }
    100%     { opacity: 0;   r: 90; stroke-width: 0.3; }
  }

  /* Generic edge variants for flow + pulse reuse the same flicker */
  .hs-edge.fe0 { animation-delay: -0s;   }
  .hs-edge.fe1 { animation-delay: -1s;   }
  .hs-edge.fe2 { animation-delay: -2s;   }
  .hs-edge.fe3 { animation-delay: -0.5s; }
  .hs-edge.fe4 { animation-delay: -1.5s; }
  .hs-edge.fe5 { animation-delay: -2.5s; }
  .hs-edge.pe0 { animation-delay: -0s;   }
  .hs-edge.pe1 { animation-delay: -0.8s; }
  .hs-edge.pe2 { animation-delay: -1.6s; }
  .hs-edge.pe3 { animation-delay: -2.4s; }
  .hs-edge.pe4 { animation-delay: -3.2s; }
  .hs-edge.pe5 { animation-delay: -4.0s; }

  /* ── Orbit variant — rings + satellites ────────────────────── */
  .hs-ring {
    stroke: rgba(0,229,255, 0.28);
    stroke-width: 1;
    stroke-dasharray: 3 5;
    transform-origin: center;
  }
  .hs-ring-outer {
    animation: hs-ring-spin 60s linear infinite;
  }
  .hs-ring-inner {
    stroke-dasharray: 2 4;
    stroke: rgba(0,229,255, 0.35);
    animation: hs-ring-spin 40s linear infinite reverse;
  }
  @keyframes hs-ring-spin {
    0%   { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: 80; }
  }

  .hs-sat rect {
    fill: #050507;
    stroke: rgba(0,229,255, 0.7);
    stroke-width: 1;
    filter: drop-shadow(0 0 3px rgba(0,229,255, 0.4));
  }
  .hs-sat-small rect {
    stroke: rgba(0,229,255, 0.85);
    stroke-width: 0.8;
    filter: drop-shadow(0 0 2px rgba(0,229,255, 0.5));
  }

  /* ── Particles ─────────────────────────────────────────────── */
  .hs-pkt {
    filter: drop-shadow(0 0 3px #00E5FF);
    opacity: 0.85;
  }
  .hs-pkt-bright {
    filter: drop-shadow(0 0 5px #00E5FF);
    opacity: 1;
  }

  /* ── Pulse rings (radial emanation) ────────────────────────── */
  .hs-pulse { mix-blend-mode: screen; }

  /* ── Reduced motion — freeze everything, keep graph visible ── */
  @media (prefers-reduced-motion: reduce) {
    .hs-aura,
    .hs-ring,
    .hs-float,
    .hs-edge,
    .hs-node-core-rect,
    .hs-fire,
    .hs-pulse,
    .hs-orbit-outer-group,
    .hs-orbit-inner-group,
    .hs-n-core rect { animation: none !important; }
    .hs-pkt, .hs-pkt-bright { opacity: 0; }
    .hs-fire, .hs-pulse { opacity: 0; }
    .hs-pkt-g, .hs-trail { opacity: 0 !important; }
  }
</style>

<script>
  // Drive the network-variant agent graph with requestAnimationFrame.
  // Each edge runs an independent phase cycle offset by i * 0.18 so packets
  // continuously flow across the graph. Traversal ~0.95s per edge, rest ~0.95s.
  (() => {
    const reduce = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches;
    if (reduce) return;
    const roots = document.querySelectorAll('.hs-agent-graph');
    if (!roots.length) return;

    // Edge segments: [x1,y1,x2,y2] matching the SVG declaration above.
    const EDGES = [
      [50, 105, 150, 80],
      [50, 105, 150, 200],
      [150, 80,  230, 140],
      [150, 200, 230, 140],
      [230, 140, 310, 110],
      [310, 110, 310, 210],
      [310, 110, 390, 150],
      [310, 210, 390, 150],
    ];

    roots.forEach((root) => {
      const offset = Number(root.getAttribute('data-offset') || '0');
      const trails = root.querySelectorAll('.hs-trail');
      const pkts   = root.querySelectorAll('.hs-pkt-g');
      let start = 0;

      // Match original SignalLiveGraph: 60fps-equivalent cycle with 120-frame period
      // (2s) per edge, active for first half, staggered i*0.3s so 4 edges are
      // traversing at any time. Trail = line from source to packet, fading as
      // packet approaches target (opacity 1 - p).
      const PERIOD = 2.0;
      const STAGGER = 0.3;
      let rafId = 0;

      const tick = (ts) => {
        if (!start) start = ts;
        const elapsed = (ts - start) / 1000 + offset;

        for (let i = 0; i < EDGES.length; i++) {
          const phase = ((elapsed + i * STAGGER) % PERIOD) / PERIOD; // 0..1
          const active = phase < 0.5;

          const trail = trails[i];
          const pkt   = pkts[i];
          if (!trail || !pkt) continue;

          if (active) {
            const p = phase * 2; // 0..1 across the edge during traversal
            const [x1, y1, x2, y2] = EDGES[i];
            const px = x1 + (x2 - x1) * p;
            const py = y1 + (y2 - y1) * p;

            // Trail: full line from source → packet position, fading out as p → 1.
            trail.setAttribute('x2', px.toFixed(2));
            trail.setAttribute('y2', py.toFixed(2));
            trail.style.opacity = String(1 - p);

            // Packet stays bright throughout the traversal (no fade on the dot).
            pkt.setAttribute('transform', `translate(${px.toFixed(2)} ${py.toFixed(2)})`);
            pkt.style.opacity = '1';
          } else {
            trail.style.opacity = '0';
            pkt.style.opacity   = '0';
          }
        }
        rafId = requestAnimationFrame(tick);
      };

      rafId = requestAnimationFrame(tick);

      // Pause when offscreen / tab hidden to save battery.
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            if (!rafId) rafId = requestAnimationFrame(tick);
          } else {
            cancelAnimationFrame(rafId);
            rafId = 0;
          }
        });
      }, { threshold: 0 });
      io.observe(root);
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) { cancelAnimationFrame(rafId); rafId = 0; }
        else if (!rafId) rafId = requestAnimationFrame(tick);
      });
    });
  })();
</script>
