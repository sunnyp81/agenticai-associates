---
interface Props {
  headline?: string;
  text?: string;
  buttonText?: string;
  buttonHref?: string;
  secondaryText?: string;
  secondaryHref?: string;
  variant?: 'dark' | 'light';
}

const {
  headline = 'Ready to Transform Your Business with AI?',
  text = 'Book a free 30-minute consultation. No commitment, no jargon — just honest advice on how AI can help your business.',
  buttonText = 'Book a Free Consultation',
  buttonHref = '/contact/',
  secondaryText,
  secondaryHref,
  variant = 'dark',
} = Astro.props;

const isDark = variant === 'dark';
---

<section class:list={[
  'section rounded-2xl mx-4 my-8 lg:mx-0',
  isDark ? 'bg-[var(--color-hero-bg)] text-white' : 'bg-[var(--color-surface)] border border-[var(--color-border)]',
]}>
  <div class="max-w-2xl mx-auto text-center">
    <h2 class:list={[
      'mb-4',
      isDark ? 'text-white' : '',
    ]}>
      {headline}
    </h2>
    <p class:list={[
      'text-lg mb-8 leading-relaxed',
      isDark ? 'text-slate-300' : 'text-[var(--color-text-muted)]',
    ]}>
      {text}
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href={buttonHref} class:list={[
        'btn',
        isDark ? 'btn-primary' : 'btn-primary',
      ]}>
        {buttonText}
      </a>
      {secondaryText && secondaryHref && (
        <a href={secondaryHref} class:list={[
          'btn',
          isDark ? 'btn-white' : 'btn-outline',
        ]}>
          {secondaryText}
        </a>
      )}
    </div>
  </div>
</section>
