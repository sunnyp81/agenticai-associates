---
interface Props {
  headline?: string;
  text?: string;
  buttonText?: string;
  buttonHref?: string;
  secondaryText?: string;
  secondaryHref?: string;
  variant?: 'dark' | 'light';
}

const {
  headline = 'Ready to Transform Your Business with AI?',
  text = 'Book a free 30-minute consultation. No commitment, no jargon — just honest advice on how AI can help your business.',
  buttonText = 'Book a Free Consultation',
  buttonHref = '/contact/',
  secondaryText,
  secondaryHref,
  variant = 'dark',
} = Astro.props;

const isDark = variant === 'dark';
---

{isDark ? (
  <!-- Dark CTA — full-width, flows into footer -->
  <section class="relative overflow-hidden py-20 px-6" style="background: #080f1e;">
    <!-- Aurora blob -->
    <div class="aurora-blob w-96 h-96 top-[-50px] left-1/4" style="background: #0d9488;"></div>
    <!-- Dot grid -->
    <div class="dot-grid absolute inset-0 opacity-[0.06]"></div>
    <div class="max-w-2xl mx-auto text-center relative">
      <h2 class="text-white mb-4">{headline}</h2>
      <p class="text-lg mb-8 leading-relaxed text-slate-300">{text}</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={buttonHref} class="btn-glow">{buttonText}</a>
        {secondaryText && secondaryHref && (
          <a href={secondaryHref} class="btn" style="background: rgba(255,255,255,0.1); color: #e2e8f0; border: 1px solid rgba(255,255,255,0.2);">{secondaryText}</a>
        )}
      </div>
    </div>
  </section>
) : (
  <!-- Light CTA — card style -->
  <section class="section rounded-2xl mx-4 my-8 lg:mx-0 bg-[var(--color-surface)] border border-[var(--color-border)]">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="mb-4">{headline}</h2>
      <p class="text-lg mb-8 leading-relaxed text-[var(--color-text-muted)]">{text}</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={buttonHref} class="btn-glow">{buttonText}</a>
        {secondaryText && secondaryHref && (
          <a href={secondaryHref} class="btn btn-outline">{secondaryText}</a>
        )}
      </div>
    </div>
  </section>
)}
