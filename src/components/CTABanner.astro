---
interface Props {
  headline?: string;
  text?: string;
  buttonText?: string;
  buttonHref?: string;
  secondaryText?: string;
  secondaryHref?: string;
  variant?: 'dark' | 'light';
}

const {
  headline = 'Let\'s see if AI can actually move your numbers.',
  text = '30-minute fit call. We\'ll confirm whether a Diagnostic is the right fit — and if it isn\'t, we\'ll say so.',
  buttonText = 'Book a Fit Call',
  buttonHref = '/contact/',
  secondaryText,
  secondaryHref,
  variant = 'dark',
} = Astro.props;
---

<section style="background: radial-gradient(ellipse at 50% 0%, rgba(13,148,136,0.18) 0%, transparent 60%), #080f1e; padding: 7rem 1.5rem; border-top: 1px solid rgba(255,255,255,0.07); position: relative; overflow: hidden;">
  <!-- Ambient glow -->
  <div style="position:absolute; top:-150px; left:50%; transform:translateX(-50%); width:600px; height:600px; background:radial-gradient(circle, rgba(13,148,136,0.12), transparent 60%); pointer-events:none;"></div>

  <div style="max-width: 680px; margin: 0 auto; text-align: center; position: relative;">
    <div style="font-family:var(--font-mono); font-size:0.65rem; letter-spacing:0.2em; color:#5eead4; margin-bottom:1.5rem; text-transform:uppercase;">[08] CONTACT</div>
    <h2 style="font-family:var(--font-grotesk); font-size:clamp(2.25rem,6vw,4rem); font-weight:500; letter-spacing:-0.03em; line-height:1; margin:0 0 1.25rem; color:#f0f9ff;">
      {headline.split('actually').length > 1 ? (
        <>
          {headline.split('actually')[0]}
          <span style="color:#5eead4; text-shadow:0 0 40px rgba(94,234,212,0.6);">actually</span>
          {headline.split('actually')[1]}
        </>
      ) : headline}
    </h2>
    <p style="font-size:1.0625rem; line-height:1.65; color:#94a3b8; margin:0 0 2.5rem; font-family:var(--font-sans);">{text}</p>
    <div style="display:flex; flex-direction:column; gap:0.75rem; align-items:center; justify-content:center;" class="sm:flex-row">
      <a href={buttonHref} class="btn-glow">{buttonText}</a>
      {secondaryText && secondaryHref && (
        <a href={secondaryHref} class="btn-outline">{secondaryText}</a>
      )}
    </div>
    <!-- Contact details -->
    <div style="margin-top:2.5rem; display:flex; flex-direction:column; gap:0.375rem; align-items:center;">
      <div style="font-family:var(--font-mono); font-size:0.75rem; color:#475569; line-height:2;">
        <span style="color:#5eead4; margin-right:0.5rem;">▸</span> hello@agenticai.associates
      </div>
      <div style="font-family:var(--font-mono); font-size:0.75rem; color:#475569;">
        <span style="color:#5eead4; margin-right:0.5rem;">▸</span> London, UK · GDPR Registered
      </div>
    </div>
  </div>
</section>

<style>
  @media (min-width: 640px) {
    .sm\:flex-row { flex-direction: row; }
  }
</style>
