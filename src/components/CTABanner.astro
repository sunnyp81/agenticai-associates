---
interface Props {
  headline?: string;
  text?: string;
  buttonText?: string;
  buttonHref?: string;
  secondaryText?: string;
  secondaryHref?: string;
  variant?: 'dark' | 'light';
}

const {
  headline = 'Ready to Transform Your Business with AI?',
  text = 'Book a free 30-minute consultation. No commitment, no jargon — just honest advice on how AI can help your business.',
  buttonText = 'Book a Free Consultation',
  buttonHref = '/contact/',
  secondaryText,
  secondaryHref,
  variant = 'dark',
} = Astro.props;

const isDark = variant === 'dark';
---

{isDark ? (
  <!-- Dark CTA — full-width, flows into footer -->
  <section class="bg-[var(--color-hero-bg)] text-white py-20 px-6">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-white mb-4">{headline}</h2>
      <p class="text-lg mb-8 leading-relaxed text-slate-300">{text}</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={buttonHref} class="btn btn-primary">{buttonText}</a>
        {secondaryText && secondaryHref && (
          <a href={secondaryHref} class="btn btn-white">{secondaryText}</a>
        )}
      </div>
    </div>
  </section>
) : (
  <!-- Light CTA — card style -->
  <section class="section rounded-2xl mx-4 my-8 lg:mx-0 bg-[var(--color-surface)] border border-[var(--color-border)]">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="mb-4">{headline}</h2>
      <p class="text-lg mb-8 leading-relaxed text-[var(--color-text-muted)]">{text}</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={buttonHref} class="btn btn-primary">{buttonText}</a>
        {secondaryText && secondaryHref && (
          <a href={secondaryHref} class="btn btn-outline">{secondaryText}</a>
        )}
      </div>
    </div>
  </section>
)}
