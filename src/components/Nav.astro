---
import { siteConfig, mainNav } from '@/data/site-config';

const currentPath = Astro.url.pathname;
---

<header id="site-nav" style="position: sticky; position: -webkit-sticky; top: 0; z-index: 100; background: rgba(5,5,7, 0.85); border-bottom: 1px solid rgba(255,255,255,0.07); backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px); transition: background 0.25s ease, border-color 0.25s ease;">
  <div class="container flex items-center justify-between" style="height: 4rem;">

    <!-- Signal logo + brand -->
    <a href="/" class="flex items-center gap-3" style="text-decoration: none;" aria-label="Agentic AI Associates home">
      <!-- Crosshair SVG logo -->
      <svg width="28" height="28" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect x="1" y="1" width="28" height="28" rx="5" stroke="#00E5FF" stroke-width="1.5"/>
        <circle cx="15" cy="15" r="3.5" fill="#00E5FF"/>
        <line x1="4" y1="15" x2="11.5" y2="15" stroke="#00E5FF" stroke-width="1.2"/>
        <line x1="18.5" y1="15" x2="26" y2="15" stroke="#00E5FF" stroke-width="1.2"/>
        <line x1="15" y1="4" x2="15" y2="11.5" stroke="#00E5FF" stroke-width="1.2"/>
        <line x1="15" y1="18.5" x2="15" y2="26" stroke="#00E5FF" stroke-width="1.2"/>
      </svg>
      <div>
        <div style="font-family: var(--font-grotesk); font-size: 0.9375rem; font-weight: 600; letter-spacing: -0.01em; color: #EDEDEA; line-height: 1.1;">AGENTIC.AI</div>
        <div style="font-family: var(--font-mono); font-size: 0.5625rem; letter-spacing: 0.18em; color: #6c6c72; line-height: 1;">ASSOCIATES / UK</div>
      </div>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
      {mainNav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'text-sm font-medium transition-colors px-3 py-2 rounded-full',
            currentPath.startsWith(item.href)
              ? 'text-[#00E5FF]'
              : 'text-[#8a8a92] hover:text-[#EDEDEA]',
          ]}
          style="font-family: var(--font-grotesk);"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Right side: LIVE indicator + CTA -->
    <div class="hidden lg:flex items-center gap-4">
      <div class="live-dot" style="margin-right: 4px;">
        <span class="live-dot-pulse"></span>
        SIGNAL · LIVE
      </div>
      <a href="/contact/" class="btn-glow" style="padding: 0.5rem 1.25rem; font-size: 0.8125rem;">
        Book a Call →
      </a>
    </div>

    <!-- Mobile toggle -->
    <button
      id="mobile-toggle"
      class="lg:hidden p-2"
      style="color: #8a8a92;"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg id="menu-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="menu-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <nav id="mobile-menu" class="hidden lg:hidden" style="border-top: 1px solid rgba(255,255,255,0.07);" aria-label="Mobile navigation">
    <div class="container py-4 flex flex-col gap-1">
      {mainNav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'py-2.5 px-3 rounded-lg text-sm font-medium transition-colors',
            currentPath.startsWith(item.href)
              ? 'text-[#00E5FF]'
              : 'text-[#8a8a92] hover:text-[#EDEDEA] hover:bg-white/5',
          ]}
          style="font-family: var(--font-grotesk);"
        >
          {item.label}
        </a>
      ))}
      <div class="flex items-center gap-3 mt-3 pt-3" style="border-top: 1px solid rgba(255,255,255,0.07);">
        <div class="live-dot">
          <span class="live-dot-pulse"></span>
          LIVE
        </div>
        <a href="/contact/" class="btn-glow text-sm flex-1 justify-center">
          Book a Call →
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-open');
  const closeIcon = document.getElementById('menu-close');
  const nav = document.getElementById('site-nav');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    openIcon?.classList.toggle('hidden', isOpen);
    closeIcon?.classList.toggle('hidden', !isOpen);
  });

  // Solidify nav background after scroll past hero
  const setNavSolid = () => {
    if (!nav) return;
    if (window.scrollY > 12) {
      nav.style.background = 'rgba(5,5,7, 0.96)';
      nav.style.borderBottomColor = 'rgba(0,229,255, 0.18)';
    } else {
      nav.style.background = 'rgba(5,5,7, 0.85)';
      nav.style.borderBottomColor = 'rgba(255,255,255,0.07)';
    }
  };
  setNavSolid();
  window.addEventListener('scroll', setNavSolid, { passive: true });
</script>
