---
import { siteConfig, footerNav } from '@/data/site-config';

const year = new Date().getFullYear();
---

<footer class="bg-[var(--color-hero-bg)] text-[var(--color-hero-text)]">
  <div class="container section-sm">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <!-- Brand -->
      <div>
        <a href="/" class="text-xl font-bold font-[family-name:var(--font-display)] text-white">
          <span class="text-gradient">Agentic AI</span>
          <span class="text-[var(--color-accent-light)] font-medium text-sm">.Associates</span>
        </a>
        <p class="mt-3 text-sm text-slate-400 leading-relaxed max-w-xs">
          {siteConfig.tagline} UK-based AI consultancy helping businesses adopt intelligent systems.
        </p>
        {siteConfig.contact.email && (
          <a href={`mailto:${siteConfig.contact.email}`} class="inline-block mt-4 text-sm text-[var(--color-accent-light)] hover:text-white transition-colors">
            {siteConfig.contact.email}
          </a>
        )}
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-400 mb-4">Services</h3>
        <ul class="space-y-2.5">
          {footerNav.services.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-300 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Industries -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-400 mb-4">Industries</h3>
        <ul class="space-y-2.5">
          {footerNav.industries.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-300 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-400 mb-4">Company</h3>
        <ul class="space-y-2.5">
          {footerNav.company.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-300 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-slate-800 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-500">
      <p>&copy; {year} {siteConfig.name}. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/privacy/" class="hover:text-slate-300 transition-colors">Privacy</a>
        <a href="/terms/" class="hover:text-slate-300 transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>
