---
import { siteConfig, footerNav } from '@/data/site-config';

const year = new Date().getFullYear();
---

<footer class="bg-[var(--color-hero-bg)] text-slate-400">
  <div class="container section-sm">
    <!-- Main grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-8 lg:gap-12 mb-12">
      <!-- Brand — spans 2 cols on mobile, 1 on lg -->
      <div class="col-span-2 md:col-span-4 lg:col-span-2">
        <a href="/" class="inline-block text-white font-semibold text-lg">
          Agentic AI<span class="text-[var(--color-accent-light)] font-normal">.associates</span>
        </a>
        <p class="mt-3 text-sm leading-relaxed max-w-sm">
          UK-based AI consultancy. We help businesses adopt intelligent systems that deliver measurable results.
        </p>
        {siteConfig.contact.email && (
          <a href={`mailto:${siteConfig.contact.email}`} class="inline-block mt-4 text-sm text-[var(--color-accent-light)] hover:text-white transition-colors">
            {siteConfig.contact.email}
          </a>
        )}
        <div class="mt-5">
          <a href="/contact/" class="inline-flex items-center gap-2 text-sm font-medium text-white bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] px-4 py-2 rounded-lg transition-colors">
            Book a Free Consultation
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-4">Services</p>
        <ul class="space-y-2">
          {footerNav.services.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Industries -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-4">Industries</p>
        <ul class="space-y-2">
          {footerNav.industries.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-4">Company</p>
        <ul class="space-y-2">
          {footerNav.company.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 border-t border-slate-800 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-slate-600">
      <p>&copy; {year} {siteConfig.name}. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/privacy/" class="hover:text-slate-400 transition-colors">Privacy</a>
        <a href="/terms/" class="hover:text-slate-400 transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>
