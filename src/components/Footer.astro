---
import { siteConfig, footerNav } from '@/data/site-config';

const year = new Date().getFullYear();
---

<footer style="background: #080f1e;" class="text-slate-400">
  <!-- Tech stack — Signal style -->
  <div style="border-bottom: 1px solid rgba(255,255,255,0.07);">
    <div class="container" style="padding: 3.5rem 1.5rem 3rem; text-align:center;">
      <p style="font-family:var(--font-mono); font-size:0.65rem; letter-spacing:0.2em; color:#5eead4; text-transform:uppercase; margin:0 0 1.75rem;">
        <span style="color:#475569;">[STACK]</span> Models · Cloud · Tooling
      </p>
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
        {['OpenAI', 'Anthropic', 'Google Cloud', 'Microsoft Azure', 'AWS', 'Hugging Face'].map(name => (
          <span class="trust-bar-logo">{name}</span>
        ))}
      </div>
    </div>
  </div>

  <div class="container" style="padding: 4rem 1.5rem 3rem;">
    <!-- Main grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-8 lg:gap-12 mb-12">
      <!-- Brand — full width on mobile/sm, spans all on md, 2 cols on lg -->
      <div class="sm:col-span-2 md:col-span-4 lg:col-span-2">
        <a href="/" class="inline-flex items-center gap-1 text-white font-semibold text-lg">
          <span class="bg-gradient-to-r from-blue-400 to-teal-400 bg-clip-text text-transparent">Agentic AI</span><span class="text-slate-400 font-normal">.associates</span>
        </a>
        <p class="mt-3 text-sm leading-relaxed max-w-sm">
          UK-based AI consultancy. We help businesses adopt intelligent systems that deliver measurable results.
        </p>
        {siteConfig.contact.email && (
          <a href={`mailto:${siteConfig.contact.email}`} class="inline-block mt-4 text-sm hover:text-white transition-colors" style="color: #5eead4;">
            {siteConfig.contact.email}
          </a>
        )}
        <div class="mt-6">
          <a href="/contact/" class="btn-glow text-sm" style="padding: 0.5rem 1.1rem;">
            Book a Discovery Call
          </a>
        </div>
        <div class="mt-5 flex flex-wrap gap-2">
          <span class="text-xs px-2.5 py-1 rounded-full border border-slate-700 text-slate-500">GDPR Ready</span>
          <span class="text-xs px-2.5 py-1 rounded-full border border-slate-700 text-slate-500">UK Registered</span>
        </div>
      </div>

      <!-- Services -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-4">What We Do</p>
        <ul class="space-y-2">
          {footerNav.whatWeDo.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Industries -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-4">Industries</p>
        <ul class="space-y-2">
          {footerNav.industries.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-4">Company</p>
        <ul class="space-y-2">
          {footerNav.company.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 border-t border-slate-800 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-slate-600">
      <p>&copy; {year} {siteConfig.name}. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/privacy/" class="hover:text-slate-400 transition-colors">Privacy</a>
        <a href="/terms/" class="hover:text-slate-400 transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>
