---
interface Props {
  steps?: { title: string; description: string }[];
}

const { steps = [
  { title: 'Discover', description: 'We audit your current processes, data, and AI readiness. No jargon — just a clear picture of where you stand.' },
  { title: 'Strategise', description: 'We build a tailored AI roadmap aligned with your business goals. Every recommendation has a clear ROI case.' },
  { title: 'Implement', description: 'We build, integrate, and deploy AI solutions. Hands-on, working alongside your team, not from an ivory tower.' },
  { title: 'Optimise', description: 'We measure, refine, and scale what works. AI is a journey, not a one-off project.' },
] } = Astro.props;
---

<section class="section-sm">
  <h2 class="text-center mb-12">How We Work</h2>
  <div class="relative max-w-5xl mx-auto">
    <!-- Connector line on lg+ -->
    <div class="hidden lg:block absolute top-7 left-[12.5%] right-[12.5%] h-px bg-gradient-to-r from-transparent via-[var(--color-accent)]/30 to-transparent" aria-hidden="true"></div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 relative">
      {steps.map((step, i) => (
        <div class="relative text-center">
          <div class="w-14 h-14 rounded-full bg-white border-2 border-[var(--color-accent)]/20 flex items-center justify-center mx-auto mb-4 relative z-10 shadow-sm">
            <span class="text-xl font-bold text-[var(--color-accent)] font-[family-name:var(--font-display)]">{i + 1}</span>
          </div>
          <h3 class="text-lg font-semibold mb-2">{step.title}</h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
